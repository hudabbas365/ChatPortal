@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero -->
<section class="hero-section d-flex align-items-center" style="min-height:100vh;background:linear-gradient(135deg,#f8f9fa 0%,#e3f2fd 50%,#f3e5f5 100%);padding-top:76px;">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <span class="badge bg-gradient px-3 py-2 mb-4 rounded-pill" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;">
                    <i class="bi bi-stars me-1"></i>Powered by GPT-4
                </span>
                <h1 class="display-4 fw-bold lh-sm mb-4" style="color:#2d3748;">
                    Your AI Chat<br><span class="text-gradient" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Assistant</span><br>for Everything
                </h1>
                <p class="lead mb-5" style="color:#4a5568;">
                    Experience next-generation AI conversations. From code reviews to creative writing,
                    ChatPortal helps you achieve more in less time.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-lg px-4 py-2 shadow" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);border:none;color:white;">
                        <i class="bi bi-rocket-takeoff me-2"></i>Get Started Free
                    </a>
                    <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 py-2">
                        <i class="bi bi-play-circle me-2"></i>Try Demo
                    </a>
                </div>
                <div class="d-flex gap-4 mt-5">
                    <div class="text-center">
                        <div class="fw-bold fs-4" style="color:#667eea;">50K+</div>
                        <div class="text-muted small">Users</div>
                    </div>
                    <div class="text-center">
                        <div class="fw-bold fs-4" style="color:#667eea;">10M+</div>
                        <div class="text-muted small">Messages</div>
                    </div>
                    <div class="text-center">
                        <div class="fw-bold fs-4" style="color:#667eea;">99.9%</div>
                        <div class="text-muted small">Uptime</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mt-5 mt-lg-0">
                <div class="chat-preview-card bg-white rounded-4 p-4 shadow-lg border border-light">
                    <div class="d-flex align-items-center gap-2 mb-4 pb-3 border-bottom">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                            <i class="bi bi-robot text-white small"></i>
                        </div>
                        <div>
                            <div class="fw-medium small" style="color:#2d3748;">ChatPortal AI</div>
                            <div class="text-success" style="font-size:0.7rem;"><i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Online</div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mb-3">
                        <div class="text-white rounded-3 p-3 small" style="max-width:75%;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                            Can you help me write a Python function to sort a list?
                        </div>
                    </div>
                    <div class="d-flex mb-3">
                        <div class="me-2">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:28px;height:28px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                                <i class="bi bi-robot text-white" style="font-size:0.7rem;"></i>
                            </div>
                        </div>
                        <div class="bg-light rounded-3 p-3 small" style="max-width:75%;color:#2d3748;">
                            Sure! Here's a clean Python function:<br>
                            <code class="text-success">def sort_list(items):<br>&nbsp;&nbsp;return sorted(items)</code>
                        </div>
                    </div>
                    <div class="input-group mt-3">
                        <input type="text" class="form-control bg-light border-0" placeholder="Type your message..." disabled style="color:#4a5568;" />
                        <button class="btn" disabled style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;"><i class="bi bi-send"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="py-6 bg-body-secondary">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold display-6">Everything you need</h2>
            <p class="text-muted lead">Powerful features to supercharge your productivity</p>
        </div>
        <div class="row g-4">
            @foreach (var feature in new[] {
                ("bi-lightning-charge", "primary", "Lightning Fast", "Get responses in milliseconds with our optimized AI infrastructure."),
                ("bi-shield-check", "success", "Secure & Private", "Your conversations are encrypted and never used for training."),
                ("bi-cpu", "info", "Multiple AI Models", "Switch between GPT-3.5, GPT-4, and more models instantly."),
                ("bi-code-slash", "warning", "Code Generation", "Write, review, and debug code with AI assistance."),
                ("bi-translate", "danger", "Multi-language", "Chat and get responses in 50+ languages."),
                ("bi-graph-up", "secondary", "Analytics", "Track your usage, credits, and productivity metrics.")
            })
            {
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 p-4">
                        <div class="feature-icon bg-@feature.Item2 bg-opacity-10 text-@feature.Item2 rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width:52px;height:52px;">
                            <i class="bi @feature.Item1 fs-4"></i>
                        </div>
                        <h5 class="fw-bold">@feature.Item3</h5>
                        <p class="text-muted small mb-0">@feature.Item4</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-6" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
    <div class="container py-5 text-center text-white">
        <h2 class="display-6 fw-bold mb-3">Ready to get started?</h2>
        <p class="lead mb-4 opacity-90">Join 50,000+ users already using ChatPortal</p>
        <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5 shadow">
            <i class="bi bi-rocket-takeoff me-2"></i>Start for Free
        </a>
    </div>
</section>
