@model ChatPortal.ViewModels.AgentChatViewModel
@{
    ViewData["Title"] = $"Chat with {Model.AgentName}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .agent-chat-layout {
        height: calc(100vh - 56px);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .agent-chat-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 20px;
        flex-shrink: 0;
    }

    .agent-chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        background: #f8f9fa;
    }

    .msg-bubble {
        max-width: 72%;
        padding: 10px 14px;
        border-radius: 16px;
        margin-bottom: 10px;
        font-size: 0.92rem;
        line-height: 1.5;
        word-break: break-word;
        white-space: pre-wrap;
    }

    .msg-user {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        margin-left: auto;
        border-bottom-right-radius: 4px;
    }

    .msg-assistant {
        background: white;
        color: #2d3748;
        border: 1px solid #e2e8f0;
        margin-right: auto;
        border-bottom-left-radius: 4px;
    }

    .msg-meta {
        font-size: 0.72rem;
        color: #a0aec0;
        margin-bottom: 2px;
    }

    .typing-indicator {
        display: none;
        align-items: center;
        gap: 6px;
        margin-bottom: 10px;
    }

    .typing-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #764ba2;
        animation: typing 1.2s infinite;
    }

    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }

    @@keyframes typing {
        0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
        30% { transform: translateY(-6px); opacity: 1; }
    }

    .agent-chat-input {
        border-top: 1px solid #e2e8f0;
        background: white;
        padding: 12px 16px;
        flex-shrink: 0;
    }

    .agent-type-badge {
        font-size: 0.72rem;
        padding: 2px 8px;
        border-radius: 12px;
        background: rgba(255,255,255,0.25);
        color: white;
        text-transform: capitalize;
    }
</style>

<div class="agent-chat-layout">

    <!-- Header -->
    <div class="agent-chat-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
            <a href="javascript:history.back()" class="btn btn-sm btn-light" style="opacity:0.85;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-robot fs-5"></i>
                    <span class="fw-semibold fs-5">@Model.AgentName</span>
                    <span class="agent-type-badge">@Model.AgentType</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.AgentDescription))
                {
                    <div style="font-size:0.78rem;opacity:0.85;margin-top:2px;">@Model.AgentDescription</div>
                }
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            @if (!string.IsNullOrEmpty(Model.ModelName))
            {
                <span style="font-size:0.78rem;opacity:0.8;"><i class="bi bi-cpu me-1"></i>@Model.ModelName</span>
            }
            <button class="btn btn-sm btn-light" onclick="newChat()" title="New Chat" style="opacity:0.85;">
                <i class="bi bi-plus-lg me-1"></i>New Chat
            </button>
        </div>
    </div>

    <!-- Messages -->
    <div class="agent-chat-messages" id="messagesArea">
        @if (!Model.History.Any())
        {
            <div class="text-center text-muted mt-5" id="emptyState">
                <i class="bi bi-chat-dots fs-1 d-block mb-2" style="color:#764ba2;opacity:0.4;"></i>
                <p class="mb-1 fw-semibold">Start a conversation with <strong>@Model.AgentName</strong></p>
                <p class="small">Type your message below and press Enter or click Send.</p>
            </div>
        }
        else
        {
            foreach (var msg in Model.History)
            {
                <div class="d-flex flex-column @(msg.Role == "user" ? "align-items-end" : "align-items-start")">
                    <div class="msg-meta">@(msg.Role == "user" ? "You" : Model.AgentName) · @msg.CreatedAt.ToString("HH:mm")</div>
                    <div class="msg-bubble @(msg.Role == "user" ? "msg-user" : "msg-assistant")">@msg.Content</div>
                </div>
            }
        }

        <!-- Typing indicator -->
        <div class="typing-indicator align-items-start" id="typingIndicator">
            <div class="msg-bubble msg-assistant d-flex align-items-center gap-1" style="padding:10px 14px;">
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
                <div class="typing-dot"></div>
            </div>
        </div>
    </div>

    <!-- Input bar -->
    <div class="agent-chat-input">
        <div class="d-flex gap-2">
            <textarea id="messageInput" class="form-control" rows="1"
                      placeholder="Type your message…"
                      style="resize:none;border-radius:12px;overflow:hidden;"
                      oninput="autoResize(this)"></textarea>
            <button class="btn shadow-sm" id="sendBtn"
                    style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;border-radius:12px;min-width:72px;"
                    onclick="sendMessage()">
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
        <div class="text-muted mt-1" style="font-size:0.72rem;">Press <kbd>Enter</kbd> to send · <kbd>Shift+Enter</kbd> for new line</div>
    </div>
</div>

@section Scripts {
<script>
    const agentId = @Model.AgentId;
    let sessionId = @(Model.SessionId.HasValue ? Model.SessionId.Value.ToString() : "null");
    const agentName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AgentName));

    const messagesArea = document.getElementById('messagesArea');
    const messageInput = document.getElementById('messageInput');
    const sendBtn = document.getElementById('sendBtn');
    const typingIndicator = document.getElementById('typingIndicator');

    // Scroll to bottom on load
    scrollToBottom();

    messageInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    function autoResize(el) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 160) + 'px';
    }

    function scrollToBottom() {
        messagesArea.scrollTop = messagesArea.scrollHeight;
    }

    function appendMessage(role, content, time) {
        const emptyState = document.getElementById('emptyState');
        if (emptyState) emptyState.remove();

        const wrapper = document.createElement('div');
        wrapper.className = 'd-flex flex-column ' + (role === 'user' ? 'align-items-end' : 'align-items-start');

        const meta = document.createElement('div');
        meta.className = 'msg-meta';
        meta.textContent = (role === 'user' ? 'You' : agentName) + ' · ' + (time || new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}));

        const bubble = document.createElement('div');
        bubble.className = 'msg-bubble ' + (role === 'user' ? 'msg-user' : 'msg-assistant');
        bubble.textContent = content;

        wrapper.appendChild(meta);
        wrapper.appendChild(bubble);
        messagesArea.insertBefore(wrapper, typingIndicator);
        scrollToBottom();
    }

    async function sendMessage() {
        const text = messageInput.value.trim();
        if (!text) return;

        messageInput.value = '';
        messageInput.style.height = 'auto';
        sendBtn.disabled = true;
        messageInput.disabled = true;

        appendMessage('user', text);

        // Show typing indicator
        typingIndicator.style.display = 'flex';
        scrollToBottom();

        try {
            const res = await fetch('@Url.Action("Chat", "Agent")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ agentId, message: text, sessionId })
            });

            const data = await res.json();

            typingIndicator.style.display = 'none';

            if (data.success) {
                sessionId = data.sessionId;
                appendMessage('assistant', data.reply);
            } else {
                appendMessage('assistant', '⚠️ Error: ' + (data.error || 'Unknown error'));
            }
        } catch (err) {
            typingIndicator.style.display = 'none';
            appendMessage('assistant', '⚠️ Network error: ' + err.message);
        } finally {
            sendBtn.disabled = false;
            messageInput.disabled = false;
            messageInput.focus();
        }
    }

    function newChat() {
        if (!confirm('Start a new chat? This will clear your current conversation view.')) return;
        sessionId = null;
        // Remove all message bubbles except typing indicator
        const children = Array.from(messagesArea.children);
        children.forEach(c => {
            if (c.id !== 'typingIndicator') c.remove();
        });
        // Restore empty state
        const empty = document.createElement('div');
        empty.id = 'emptyState';
        empty.className = 'text-center text-muted mt-5';
        empty.innerHTML = '<i class="bi bi-chat-dots fs-1 d-block mb-2" style="color:#764ba2;opacity:0.4;"></i><p class="mb-1 fw-semibold">Start a new conversation with <strong>' + agentName + '</strong></p><p class="small">Type your message below and press Enter or click Send.</p>';
        messagesArea.insertBefore(empty, typingIndicator);
    }
</script>
}
