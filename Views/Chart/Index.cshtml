@model List<ChatPortal.Models.Entities.Dashboard>
@{
    ViewData["Title"] = "My Charts & Dashboards";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-bar-chart-line me-2" style="color:#667eea;"></i>My Charts</h2>
            <p class="text-muted mb-0">View and manage your pinned charts and dashboards</p>
        </div>
        <a asp-action="Visuals" class="btn btn-primary rounded-3">
            <i class="bi bi-grid me-2"></i>All Pinned Visuals
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bar-chart display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No dashboards yet</h4>
            <p class="text-muted">Create dashboards and pin charts from your query results in the Chat section.</p>
            <a asp-controller="Chat" asp-action="Index" class="btn btn-primary mt-2">Go to Chat</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var dashboard in Model)
            {
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-layout-text-window-reverse fs-4 me-2" style="color:#667eea;"></i>
                                <h5 class="card-title mb-0 fw-semibold">@dashboard.Title</h5>
                            </div>
                            @if (!string.IsNullOrEmpty(dashboard.Description))
                            {
                                <p class="text-muted small mb-3">@dashboard.Description</p>
                            }
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge bg-light text-dark border">
                                    <i class="bi bi-pin me-1"></i>@dashboard.PinnedCharts.Count charts
                                </span>
                                @if (dashboard.IsPublic && !dashboard.IsRevoked)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-share me-1"></i>Shared
                                    </span>
                                }
                            </div>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-calendar3 me-1"></i>
                                Created @dashboard.CreatedAt.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                            <div class="d-flex gap-2">
                                <a asp-action="Visuals" class="btn btn-sm btn-outline-primary flex-grow-1">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                                <button class="btn btn-sm btn-outline-secondary" onclick="shareChart(@dashboard.Id)">
                                    <i class="bi bi-share"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
function shareChart(dashboardId) {
    fetch('/Chart/Share', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
        },
        body: `dashboardId=${dashboardId}`
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            navigator.clipboard?.writeText(data.shareUrl).catch(() => {});
            alert('Share link copied to clipboard:\n' + data.shareUrl);
        } else {
            alert('Error: ' + data.error);
        }
    });
}
</script>
@Html.AntiForgeryToken()
}
