@{
    ViewData["Title"] = "Create Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero py-4 mb-4" style="background: linear-gradient(135deg, #E8F0FE 0%, #F3E8FF 100%);">
    <div class="container">
        <h1 class="h3 fw-bold mb-1"><i class="bi bi-plus-circle me-2 text-primary"></i>Create Dashboard</h1>
        <p class="text-muted mb-0">Set up a new dashboard to organize your pinned charts.</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-4">
                    <form method="post" asp-action="Create">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Dashboard Title <span class="text-danger">*</span></label>
                            <input type="text" name="title" class="form-control" placeholder="e.g. Sales Overview Q4" required maxlength="256" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="description" class="form-control" rows="3" placeholder="Optional description..." maxlength="1000"></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Create Dashboard
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
