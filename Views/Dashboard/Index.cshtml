@model ChatPortal.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dashboard-container {
        background: linear-gradient(135deg, #f8f9fa 0%, #e8eaf6 100%);
        min-height: 100vh;
    }
    .stat-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: none;
        background: white;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 30px rgba(102, 126, 234, 0.15) !important;
    }
    .gradient-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
    .activity-item {
        transition: background 0.2s;
    }
    .activity-item:hover {
        background: rgba(102, 126, 234, 0.05);
    }
    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="dashboard-container py-4" style="padding-top:76px!important;">
    <div class="container-fluid">
        <!-- Page Header with User Info -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                    <div>
                        <h2 class="fw-bold mb-1" style="color:#2d3748;">Welcome back, @Model.UserName! 👋</h2>
                        <p class="text-muted mb-0">Here's what's happening with your AI workspace today</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-controller="Chat" asp-action="Index" class="btn shadow-sm" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;">
                            <i class="bi bi-plus-lg me-2"></i>New Chat
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-secondary shadow-sm" title="Logout">
                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="row g-4 mb-4">
            @{
                var statColors = new[] {
                    (Bg: "linear-gradient(135deg, #667eea 0%, #764ba2 100%)", Icon: "#667eea"),
                    (Bg: "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)", Icon: "#f093fb"),
                    (Bg: "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)", Icon: "#4facfe"),
                    (Bg: "linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)", Icon: "#43e97b")
                };
                var colorIndex = 0;
            }
            @foreach (var stat in Model.Stats)
            {
                var color = statColors[colorIndex++ % statColors.Length];
                <div class="col-md-6 col-lg-3">
                    <div class="card stat-card shadow-sm rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="flex-grow-1">
                                    <p class="text-muted small mb-2" style="text-transform:uppercase;letter-spacing:0.5px;font-weight:600;">@stat.Label</p>
                                    <h3 class="fw-bold mb-0" style="color:#2d3748;">@stat.Value</h3>
                                </div>
                                <div class="stat-icon" style="background:@color.Bg;">
                                    <i class="bi @stat.Icon fs-4 text-white"></i>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-1 text-success small">
                                <i class="bi bi-arrow-up"></i>
                                <span>12% vs last week</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row g-4 mb-4">
            <!-- Credits & Plan -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0" style="color:#2d3748;">Credit Usage</h5>
                            <span class="badge rounded-pill px-3 py-2" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);font-size:0.85rem;">@Model.PlanName Plan</span>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="small text-muted">@Model.CreditsUsed / @(Model.CreditsUsed + Model.CreditsRemaining) credits used</span>
                                <span class="small fw-bold" style="color:#667eea;">@((int)((double)Model.CreditsUsed / (Model.CreditsUsed + Model.CreditsRemaining) * 100))%</span>
                            </div>
                            <div class="progress" style="height:12px;border-radius:10px;background:#e8eaf6;">
                                <div class="progress-bar rounded-pill" style="background:linear-gradient(90deg,#667eea 0%,#764ba2 100%);width:@(Model.CreditsUsed * 100 / (Model.CreditsUsed + Model.CreditsRemaining))%"></div>
                            </div>
                        </div>
                        <div class="row g-3 mt-2">
                            <div class="col-6">
                                <div class="p-3 rounded-3" style="background:#f8f9fa;">
                                    <div class="small text-muted mb-1">Credits Used</div>
                                    <div class="h5 fw-bold mb-0" style="color:#2d3748;">@Model.CreditsUsed</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 rounded-3" style="background:#f8f9fa;">
                                    <div class="small text-muted mb-1">Credits Remaining</div>
                                    <div class="h5 fw-bold mb-0" style="color:#667eea;">@Model.CreditsRemaining</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Upgrade Plan Card -->
            <div class="col-lg-4">
                <div class="card gradient-card shadow-sm rounded-4 h-100 text-white">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="mb-3">
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;background:rgba(255,255,255,0.2);">
                                <i class="bi bi-rocket-takeoff fs-4"></i>
                            </div>
                        </div>
                        <h5 class="fw-bold mb-2">Upgrade Your Plan</h5>
                        <p class="opacity-90 mb-4">Get more credits, advanced features, and priority support</p>
                        <div class="mt-auto">
                            <a asp-controller="Pricing" asp-action="Index" class="btn btn-light w-100 shadow-sm">
                                <i class="bi bi-arrow-right me-2"></i>View Plans
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="row">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-transparent border-0 pt-4 px-4 pb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0" style="color:#2d3748;">Recent Activity</h5>
                            <a href="#" class="text-decoration-none small" style="color:#667eea;">View all</a>
                        </div>
                    </div>
                    <div class="card-body p-4 pt-2">
                        @foreach (var activity in Model.RecentActivity)
                        {
                            <div class="activity-item d-flex align-items-center gap-3 py-3 px-3 rounded-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                                    <i class="bi @activity.Icon text-white"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-medium" style="color:#2d3748;">@activity.Action</div>
                                    <small class="text-muted">@activity.Time</small>
                                </div>
                                <i class="bi bi-chevron-right text-muted"></i>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
