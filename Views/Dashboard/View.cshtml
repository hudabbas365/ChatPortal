@model ChatPortal.Models.Entities.Dashboard
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero py-4 mb-4" style="background: linear-gradient(135deg, #E8F0FE 0%, #F3E8FF 100%);">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h1 class="h3 fw-bold mb-1">
                    <i class="bi bi-grid-fill me-2 text-primary"></i>@Model.Title
                    @if (Model.IsPublic && !Model.IsRevoked)
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle ms-2 fs-6">
                            <i class="bi bi-globe2 me-1"></i>Public
                        </span>
                    }
                </h1>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mb-0">@Model.Description</p>
                }
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                @if (!Model.IsPublic || Model.IsRevoked)
                {
                    <form method="post" asp-action="Share" asp-route-id="@Model.Id">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-sm">
                            <i class="bi bi-share me-1"></i>Share Dashboard
                        </button>
                    </form>
                }
                else
                {
                    <div class="input-group input-group-sm" style="max-width:360px;">
                        <input type="text" class="form-control form-control-sm" id="publicUrl"
                               value="@($"{Context.Request.Scheme}://{Context.Request.Host}/embed/dashboard/{Model.PublicSlug}")" readonly />
                        <button class="btn btn-outline-secondary" type="button" onclick="copyUrl()">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                }
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>Back
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.IsPublic && !Model.IsRevoked)
    {
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle me-2"></i>
            <strong>Embed Code:</strong>
            <code class="ms-2">&lt;iframe src="@($"{Context.Request.Scheme}://{Context.Request.Host}/embed/dashboard/{Model.PublicSlug}")" width="100%" height="600" frameborder="0"&gt;&lt;/iframe&gt;</code>
        </div>
    }

    @if (!Model.PinnedCharts.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bar-chart display-1 text-muted opacity-25"></i>
            <h4 class="mt-3 text-muted">No charts pinned yet</h4>
            <p class="text-muted">Go to Data Insights, run a query, and pin a chart to this dashboard.</p>
            <a asp-controller="DataInsights" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>Go to Data Insights
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var chart in Model.PinnedCharts.OrderBy(c => c.Position))
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
                        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-3 pb-0">
                            <h6 class="fw-semibold mb-0">@chart.Title</h6>
                            <form method="post" asp-action="UnpinChart" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="pinnedChartId" value="@chart.Id" />
                                <button type="submit" class="btn btn-link btn-sm text-danger p-0" title="Unpin" onclick="return confirm('Remove this chart?')">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        </div>
                        <div class="card-body">
                            <div class="chart-placeholder bg-light rounded d-flex align-items-center justify-content-center" style="height:200px;">
                                <span class="text-muted"><i class="bi bi-bar-chart-fill fs-1 opacity-50"></i></span>
                            </div>
                            <p class="text-muted small mt-2 mb-0">Pinned @chart.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
function copyUrl() {
    document.getElementById('publicUrl').select();
    navigator.clipboard.writeText(document.getElementById('publicUrl').value)
        .then(() => alert('URL copied to clipboard!'));
}
</script>
}
