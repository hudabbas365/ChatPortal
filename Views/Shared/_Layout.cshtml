<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChatPortal</title>
    @if (ViewData["MetaDescription"] is string metaDesc && !string.IsNullOrEmpty(metaDesc))
    {
        <meta name="description" content="@metaDesc" />
    }
    @if (ViewData["MetaKeywords"] is string metaKw && !string.IsNullOrEmpty(metaKw))
    {
        <meta name="keywords" content="@metaKw" />
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top shadow-sm border-bottom">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold fs-4" href="/" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                <i class="bi bi-robot me-1" style="color:#667eea;"></i>ChatPortal
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>

                    @* Viewer and above: dashboards, reports, announcements *@
                    <li class="nav-item"><a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Blog" asp-action="Index">Blog</a></li>

                    @* Member, Contributor, Admin, Super Admin: chat, tasks, data (authenticated users only) *@
                    @if (User.Identity?.IsAuthenticated == true &&
                         (User.IsInRole("Member") || User.IsInRole("Contributor") ||
                          User.IsInRole("Admin") || User.IsInRole("Super Admin") ||
                          User.IsInRole("User")))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Chat" asp-action="Index">Chat</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="DataConnection" asp-action="Index">My Data</a></li>
                    }

                    @* Admin and Super Admin: workspace settings, user management *@
                    @if (User.IsInRole("Admin") || User.IsInRole("Super Admin"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Admin</a></li>
                    }

                    @* Super Admin: billing, feature toggles, tenant settings *@
                    @if (User.IsInRole("Super Admin"))
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Payment" asp-action="SelectPlan">Billing</a></li>
                    }
                    else
                    {
                        @* Pricing visible for all non-Super Admin authenticated users *@
                        <li class="nav-item"><a class="nav-link" asp-controller="Pricing" asp-action="Index">Pricing</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Payment" asp-action="SelectPlan">Credits</a></li>
                        }
                    }

                    <li class="nav-item"><a class="nav-link" asp-controller="Pages" asp-action="Docs">Docs</a></li>
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer py-4 mt-auto" style="background:linear-gradient(135deg,#f8f9fa 0%,#e8eaf6 100%);border-top:1px solid #e0e0e0;">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h6 class="fw-bold" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                        <i class="bi bi-robot me-1" style="color:#667eea;"></i>ChatPortal
                    </h6>
                    <p class="text-muted small">AI-powered chat platform for individuals and teams.</p>
                </div>
                <div class="col-md-2 mb-3">
                    <h6 class="fw-bold text-secondary small text-uppercase">Product</h6>
                    <ul class="list-unstyled">
                        <li><a href="/pricing" class="text-muted text-decoration-none small">Pricing</a></li>
                        <li><a href="/chat" class="text-muted text-decoration-none small">Chat</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-3">
                    <h6 class="fw-bold text-secondary small text-uppercase">Company</h6>
                    <ul class="list-unstyled">
                        <li><a href="/blog" class="text-muted text-decoration-none small">Blog</a></li>
                        <li><a href="/Pages/About" class="text-muted text-decoration-none small">About</a></li>
                        <li><a href="/Pages/Contact" class="text-muted text-decoration-none small">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-3">
                    <h6 class="fw-bold text-secondary small text-uppercase">Developers</h6>
                    <ul class="list-unstyled">
                        <li><a href="/Pages/Docs" class="text-muted text-decoration-none small">API Docs</a></li>
                        <li><a href="/Pages/History" class="text-muted text-decoration-none small">Chat History</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3 text-md-end">
                    <p class="text-muted small">&copy; 2025 ChatPortal. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
