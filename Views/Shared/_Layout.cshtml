<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ChatPortal</title>
    @if (ViewData["MetaDescription"] is string metaDesc && !string.IsNullOrEmpty(metaDesc))
    {
        <meta name="description" content="@metaDesc" />
    }
    @if (ViewData["MetaKeywords"] is string metaKw && !string.IsNullOrEmpty(metaKw))
    {
        <meta name="keywords" content="@metaKw" />
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold fs-4" href="/">
                <i class="bi bi-robot text-primary me-1"></i>ChatPortal
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Chat" asp-action="Index">Chat</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="DataConnection" asp-action="Index">My Data</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Payment" asp-action="SelectPlan">Credits</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Pricing" asp-action="Index">Pricing</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Blog" asp-action="Index">Blog</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Pages" asp-action="Docs">Docs</a></li>
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    @{
        var activeAnnouncements = ViewBag.ActiveAnnouncements as List<ChatPortal.Models.Entities.GlobalAnnouncement>;
    }
    @if (activeAnnouncements != null && activeAnnouncements.Any())
    {
        foreach (var ann in activeAnnouncements)
        {
            var (alertClass, icon) = ann.Priority switch
            {
                "urgent" => ("danger", "bi-exclamation-triangle-fill"),
                "warning" => ("warning", "bi-exclamation-circle-fill"),
                _ => ("info", "bi-info-circle-fill")
            };
            @* padding-top offsets the fixed-top navbar (60px) *@
            <div class="alert alert-@alertClass alert-dismissible mb-0 rounded-0 border-0 py-2" role="alert" style="padding-top:60px !important;">
                <div class="container-fluid px-4 d-flex align-items-center gap-2" style="padding-top:0 !important;">
                    <i class="bi @icon"></i>
                    <strong>@ann.Title</strong> — @ann.Content
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Dismiss"></button>
                </div>
            </div>
        }
    }

    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer bg-dark text-light py-4 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h6 class="fw-bold"><i class="bi bi-robot text-primary me-1"></i>ChatPortal</h6>
                    <p class="text-muted small">AI-powered chat platform for individuals and teams.</p>
                </div>
                <div class="col-md-2 mb-3">
                    <h6 class="fw-bold text-muted small text-uppercase">Product</h6>
                    <ul class="list-unstyled">
                        <li><a href="/pricing" class="text-muted text-decoration-none small">Pricing</a></li>
                        <li><a href="/chat" class="text-muted text-decoration-none small">Chat</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-3">
                    <h6 class="fw-bold text-muted small text-uppercase">Company</h6>
                    <ul class="list-unstyled">
                        <li><a href="/blog" class="text-muted text-decoration-none small">Blog</a></li>
                        <li><a href="/Pages/About" class="text-muted text-decoration-none small">About</a></li>
                        <li><a href="/Pages/Contact" class="text-muted text-decoration-none small">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-3">
                    <h6 class="fw-bold text-muted small text-uppercase">Developers</h6>
                    <ul class="list-unstyled">
                        <li><a href="/Pages/Docs" class="text-muted text-decoration-none small">API Docs</a></li>
                        <li><a href="/Pages/History" class="text-muted text-decoration-none small">Chat History</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3 text-md-end">
                    <p class="text-muted small">&copy; 2025 ChatPortal. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
