<div class="sidebar bg-dark text-white d-flex flex-column p-3" style="width:260px;min-height:100vh;">
    <div class="mb-4">
        <a href="/" class="text-decoration-none text-white fw-bold fs-5">
            <i class="bi bi-robot text-primary me-2"></i>ChatPortal
        </a>
    </div>
    <nav class="flex-grow-1">
        <ul class="nav flex-column gap-1">
            <li class="nav-item">
                <a class="nav-link text-white-50 d-flex align-items-center gap-2 rounded px-3 py-2" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white-50 d-flex align-items-center gap-2 rounded px-3 py-2" asp-controller="Chat" asp-action="Index">
                    <i class="bi bi-chat-dots"></i> Chat
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white-50 d-flex align-items-center gap-2 rounded px-3 py-2" asp-controller="Account" asp-action="Settings">
                    <i class="bi bi-gear"></i> Settings
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white-50 d-flex align-items-center gap-2 rounded px-3 py-2" asp-controller="Notifications" asp-action="Index">
                    <i class="bi bi-bell"></i> Notifications
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white-50 d-flex align-items-center gap-2 rounded px-3 py-2" asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-shield-check"></i> Admin
                </a>
            </li>
        </ul>
    </nav>
    <div class="mt-auto pt-3 border-top border-secondary">
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
            </button>
        </form>
    </div>
</div>
