<div class="sidebar d-flex flex-column p-3 shadow-sm" style="width:260px;min-height:100vh;background:linear-gradient(180deg,#f8f9fa 0%,#e8eaf6 100%);">
    <div class="mb-4 pb-3 border-bottom">
        <a href="/" class="text-decoration-none fw-bold fs-5" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <i class="bi bi-robot me-2" style="color:#667eea;"></i>ChatPortal
        </a>
    </div>
    <nav class="flex-grow-1">
        <ul class="nav flex-column gap-2">
            <li class="nav-item">
                <a class="nav-link d-flex align-items-center gap-3 rounded-3 px-3 py-2 sidebar-link" asp-controller="Dashboard" asp-action="Index" style="color:#4a5568;">
                    <i class="bi bi-speedometer2 fs-5"></i>
                    <span class="fw-medium">Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link d-flex align-items-center gap-3 rounded-3 px-3 py-2 sidebar-link" asp-controller="Chat" asp-action="Index" style="color:#4a5568;">
                    <i class="bi bi-chat-dots fs-5"></i>
                    <span class="fw-medium">Chat</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link d-flex align-items-center gap-3 rounded-3 px-3 py-2 sidebar-link" asp-controller="DataConnection" asp-action="Index" style="color:#4a5568;">
                    <i class="bi bi-database fs-5"></i>
                    <span class="fw-medium">My Data</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link d-flex align-items-center gap-3 rounded-3 px-3 py-2 sidebar-link" asp-controller="Account" asp-action="Settings" style="color:#4a5568;">
                    <i class="bi bi-gear fs-5"></i>
                    <span class="fw-medium">Settings</span>
                </a>
            </li>
        </ul>
    </nav>
    <div class="mt-auto pt-3 border-top">
        <div class="p-3 rounded-3 mb-3" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
            <div class="text-white">
                <div class="small opacity-90 mb-1">Your Plan</div>
                <div class="fw-bold">Pro Account</div>
            </div>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary w-100 rounded-3">
                <i class="bi bi-box-arrow-right me-2"></i>Logout
            </button>
        </form>
    </div>
</div>

<style>
    .sidebar-link {
        transition: all 0.2s;
    }
    .sidebar-link:hover {
        background: rgba(102, 126, 234, 0.1) !important;
        color: #667eea !important;
    }
    .sidebar-link.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        color: white !important;
    }
</style>
