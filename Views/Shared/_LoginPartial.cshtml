@if (Context.Request.Cookies.ContainsKey("access_token"))
{
    <div class="d-flex align-items-center gap-2">
        <partial name="_Notification" />
        <a class="nav-link text-light" asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-speedometer2 me-1"></i>Dashboard
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-light btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
            </button>
        </form>
    </div>
}
else
{
    <div class="d-flex gap-2">
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Login</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Get Started</a>
    </div>
}
