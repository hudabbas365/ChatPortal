@model ChatPortal.ViewModels.ChatViewModel
@{
    ViewData["Title"] = "Chat";
    ViewData["MetaDescription"] = "Chat with ChatPortal AI — your intelligent assistant for code, writing, analysis, and more.";
    ViewData["MetaKeywords"] = "AI chat, ChatPortal, GPT, assistant, code help, writing";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="chat-layout d-flex position-relative" style="height:calc(100vh - 56px);overflow:hidden;">

    <!-- ── Left Sidebar: Conversation History ── -->
    <div class="chat-sidebar bg-dark text-white d-flex flex-column border-end border-secondary border-opacity-25" style="width:280px;flex-shrink:0;">

        <!-- Workspace Selector -->
        <div class="p-3 border-bottom border-secondary border-opacity-25">
            <label class="text-muted mb-1 d-block" style="font-size:0.68rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">Workspace</label>
            <div class="dropdown w-100">
                <button class="btn btn-sm w-100 text-start d-flex align-items-center justify-content-between"
                        style="background:rgba(143,217,251,0.12);border:1px solid rgba(143,217,251,0.25);color:#fff;"
                        type="button" data-bs-toggle="dropdown">
                    <span><i class="bi bi-grid-fill me-2" style="color:#8FD9FB;font-size:0.8rem;"></i><span id="activeWorkspaceName">General Workspace</span></span>
                    <i class="bi bi-chevron-down" style="font-size:0.7rem;opacity:0.6;"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-dark w-100 shadow">
                    <li>
                        <a class="dropdown-item workspace-option active-workspace d-flex align-items-center gap-2" href="#" data-workspace="General Workspace">
                            <i class="bi bi-grid-fill" style="color:#8FD9FB;font-size:0.8rem;"></i>
                            <div>
                                <div style="font-size:0.85rem;">General Workspace</div>
                                <div class="text-muted" style="font-size:0.7rem;">General Purpose Agent</div>
                            </div>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li>
                        <a class="dropdown-item d-flex align-items-center gap-2 text-muted" href="/Account/Settings" style="font-size:0.82rem;">
                            <i class="bi bi-plus-circle me-1"></i>Manage Workspaces
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- New Chat + Search -->
        <div class="p-3 border-bottom border-secondary border-opacity-25">
            <button class="btn w-100 mb-2" style="background:var(--cp-accent);color:var(--cp-primary-text,#1a5276);font-weight:600;" onclick="newChat()">
                <i class="bi bi-plus-lg me-2"></i>New Chat
            </button>
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-secondary border-0 text-muted"><i class="bi bi-search"></i></span>
                <input type="text" id="sessionSearch" class="form-control bg-secondary border-0 text-white shadow-none"
                       placeholder="Search conversations…" style="font-size:0.8rem;">
            </div>
        </div>

        <!-- Session List -->
        <div class="flex-grow-1 overflow-auto p-2" id="sessionList">
            <!-- Rendered by chatHistory.js -->
        </div>

        <!-- User Info -->
        <div class="p-3 border-top border-secondary border-opacity-25">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:32px;height:32px;background:rgba(143,217,251,0.25);">
                    <i class="bi bi-person" style="color:#8FD9FB;font-size:0.9rem;"></i>
                </div>
                <div class="overflow-hidden flex-grow-1">
                    <div class="small fw-medium text-truncate">Demo User</div>
                    <div class="text-muted" style="font-size:0.7rem;">Free Plan</div>
                </div>
                <a href="/Account/Settings" class="text-muted" title="Settings" style="font-size:0.85rem;">
                    <i class="bi bi-gear"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- ── Central Chat Area ── -->
    <div class="chat-main flex-grow-1 d-flex flex-column bg-body" style="min-width:0;">
        <!-- Chat Header -->
        <div class="chat-header d-flex align-items-center justify-content-between p-3 border-bottom bg-body shadow-sm">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:40px;height:40px;background:rgba(143,217,251,0.2);">
                    <i class="bi bi-robot" style="color:var(--cp-accent,#8FD9FB);font-size:1.1rem;"></i>
                </div>
                <div>
                    <div class="fw-medium">ChatPortal AI</div>
                    <div class="small" style="color:#2ecc71;"><i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Ready</div>
                </div>
            </div>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <select id="modelSelect" class="form-select form-select-sm" style="width:auto;">
                    @foreach (var aiModel in Model.AvailableModels)
                    {
                        <option value="@aiModel" selected="@(aiModel == Model.SelectedModel)">@aiModel</option>
                    }
                </select>
                <!-- Export PDF -->
                <button class="btn btn-sm btn-outline-secondary" title="Export as PDF" onclick="exportAsPDF()">
                    <i class="bi bi-file-earmark-pdf"></i>
                </button>
                <!-- Toggle Right Panel -->
                <button class="btn btn-sm btn-outline-secondary" id="togglePanelBtn" title="Source references" onclick="toggleRightPanel()">
                    <i class="bi bi-layout-sidebar-reverse"></i>
                </button>
                <!-- Publish as iframe (agents only) -->
                @if (User.IsInRole("Agent") || User.Identity?.IsAuthenticated == true)
                {
                    <button class="btn btn-sm btn-outline-secondary" title="Publish conversation as iframe"
                            data-bs-toggle="modal" data-bs-target="#embedModal">
                        <i class="bi bi-code-slash"></i>
                    </button>
                }
                <!-- Clear Chat -->
                <button class="btn btn-sm btn-outline-secondary" title="Clear chat" onclick="clearChat()">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
        </div>

        <!-- Messages -->
        <div class="chat-messages flex-grow-1 overflow-auto p-4" id="chatMessages">
            <!-- Messages rendered by JS / chatHistory.js -->
        </div>

        <!-- File Attachment Chip -->
        <div id="attachmentChip" class="px-3 pt-2" style="display:none;"></div>

        <!-- Input Area -->
        <div class="chat-input-area p-3 border-top bg-body shadow-sm">
            <div class="container-lg">
                @Html.AntiForgeryToken()
                <div class="input-group shadow-sm rounded-3 overflow-hidden border">
                    <!-- Hidden file input -->
                    <input type="file" id="fileInput" class="d-none" accept=".txt,.csv,.json,.pdf"
                           onchange="handleFileSelected(event)" />
                    <!-- Attach button -->
                    <button class="btn btn-outline-secondary border-0 px-3" type="button"
                            title="Attach file (.txt, .csv, .json, .pdf)" onclick="triggerFileAttach()">
                        <i class="bi bi-paperclip"></i>
                    </button>
                    <textarea id="messageInput" class="form-control border-0 shadow-none"
                              placeholder="Message ChatPortal AI… (Enter to send, Shift+Enter for new line)" rows="1"
                              style="resize:none;max-height:200px;"
                              onkeydown="handleKeyDown(event)"></textarea>
                    <button class="btn btn-outline-secondary border-0 px-3" id="micBtn" type="button"
                            title="Voice input (Web Speech API)" onclick="toggleMic()">
                        <i class="bi bi-mic-fill" id="micIcon"></i>
                    </button>
                    <button class="btn px-4" id="sendBtn" style="background:var(--cp-accent);color:var(--cp-primary-text,#1a5276);" onclick="sendMessage()">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
                <div class="text-center mt-2">
                    <small class="text-muted">ChatPortal AI may produce inaccurate results. <a href="/pages/docs" class="text-muted">Learn more</a></small>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Right Panel: Source References ── -->
    <div id="rightPanel" class="chat-right-panel bg-dark text-white border-start border-secondary border-opacity-25 d-flex flex-column"
         style="width:300px;flex-shrink:0;transition:width 0.25s ease,opacity 0.25s ease;overflow:hidden;opacity:0;width:0;">
        <div class="p-3 border-bottom border-secondary border-opacity-25 d-flex justify-content-between align-items-center">
            <span class="small fw-semibold text-uppercase text-muted">Source References</span>
            <button class="btn btn-sm text-muted border-0 p-0" onclick="toggleRightPanel()" title="Close panel">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="flex-grow-1 overflow-auto" id="rightPanelContent">
            <div class="text-center text-muted py-5 px-3">
                <i class="bi bi-database fs-3 mb-2 d-block opacity-25"></i>
                <p class="small">Data references from AI responses will appear here.</p>
            </div>
        </div>
    </div>
</div>

<!-- ── Embed / Publish as iframe Modal ── -->
<div class="modal fade" id="embedModal" tabindex="-1" aria-labelledby="embedModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="embedModalLabel">
                    <i class="bi bi-code-slash me-2" style="color:var(--cp-accent);"></i>Publish Conversation as iFrame
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-3">
                <p class="text-muted small mb-3">
                    Generate an embed token and copy the snippet below into any webpage to embed this chat interface.
                </p>
                <div class="d-flex gap-2 mb-3">
                    <button class="btn btn-primary btn-sm" id="generateEmbedTokenBtn" onclick="generateEmbedToken()">
                        <i class="bi bi-key me-1"></i>Generate Embed Token
                    </button>
                    <span id="embedTokenStatus" class="small text-muted align-self-center"></span>
                </div>
                <div id="embedCodeSection" class="d-none">
                    <label class="form-label fw-semibold small">Embed Token</label>
                    <div class="input-group input-group-sm mb-3">
                        <input type="text" id="embedTokenDisplay" class="form-control font-monospace small" readonly />
                        <button class="btn btn-outline-secondary" type="button" onclick="copyEmbedToken()">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                    <label class="form-label fw-semibold small">iFrame Snippet</label>
                    <div class="input-group input-group-sm">
                        <textarea id="embedIframeCode" class="form-control font-monospace small" rows="3" readonly></textarea>
                        <button class="btn btn-outline-secondary" type="button" onclick="copyIframeCode()">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                    <p class="text-muted mt-2" style="font-size:0.78rem;">
                        <i class="bi bi-info-circle me-1"></i>The token expires based on your session settings.
                        Generate a new one when it expires.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<!-- Markdown parsing -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<!-- XSS sanitisation -->
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.6/dist/purify.min.js"></script>
<!-- Syntax highlighting -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<!-- PDF export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<!-- SignalR -->
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
<!-- Chat history (localStorage) must load before chat.js -->
<script src="~/js/chatHistory.js" asp-append-version="true"></script>
<script src="~/js/chat.js" asp-append-version="true"></script>
<script>
    // Configure marked.js
    if (typeof marked !== 'undefined') {
        marked.setOptions({ breaks: true, gfm: true });
    }

    // SignalR
    const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/chat").build();
    connection.start().catch(err => console.warn("SignalR:", err));
    connection.on("ReceiveMessage", (role, content) => appendMessage(role, content));

    // Workspace switcher
    document.querySelectorAll('.workspace-option').forEach(item => {
        item.addEventListener('click', function (e) {
            e.preventDefault();
            document.querySelectorAll('.workspace-option').forEach(i => i.classList.remove('active-workspace'));
            this.classList.add('active-workspace');
            document.getElementById('activeWorkspaceName').textContent = this.dataset.workspace;
        });
    });

    // ── Agent embed helpers ───────────────────────────────────────────────
    async function generateEmbedToken() {
        const btn = document.getElementById('generateEmbedTokenBtn');
        const status = document.getElementById('embedTokenStatus');
        btn.disabled = true;
        status.textContent = 'Generating\u2026';
        try {
            const resp = await fetch('/Account/GenerateEmbedToken', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                }
            });
            const data = await resp.json();
            if (data.success && data.token) {
                const origin = window.location.origin;
                const iframeUrl = `${origin}/Embed/Chat?token=${encodeURIComponent(data.token)}`;
                document.getElementById('embedTokenDisplay').value = data.token;
                document.getElementById('embedIframeCode').value =
                    `<iframe src="${iframeUrl}" width="400" height="600" frameborder="0" allow="microphone"></iframe>`;
                document.getElementById('embedCodeSection').classList.remove('d-none');
                status.textContent = '';
            } else {
                status.textContent = data.error || 'Failed to generate token.';
            }
        } catch {
            status.textContent = 'Request failed. Please try again.';
        } finally {
            btn.disabled = false;
        }
    }

    function copyEmbedToken() {
        const el = document.getElementById('embedTokenDisplay');
        navigator.clipboard?.writeText(el.value).catch(() => { el.select(); document.execCommand('copy'); });
    }

    function copyIframeCode() {
        const el = document.getElementById('embedIframeCode');
        navigator.clipboard?.writeText(el.value).catch(() => { el.select(); document.execCommand('copy'); });
    }
</script>
<style>
    /* Session sidebar styles */
    .session-item { transition: background 0.15s; }
    .session-item:hover { background: rgba(255,255,255,0.07); }
    .session-active { background: rgba(143,217,251,0.2) !important; }

    /* Workspace dropdown active */
    .active-workspace { background: rgba(143,217,251,0.15) !important; }

    /* Right panel slide */
    #rightPanel.panel-open { width: 300px !important; opacity: 1 !important; }

    /* Chat bubbles with new palette */
    .chat-bubble-ai { background: var(--bs-secondary-bg); }
    .chat-bubble-user { background: #8FD9FB; color: #1a5276; }
    .chat-bubble-ai pre { background: #1e1e2e; color: #cdd6f4; padding: 0.75rem; border-radius: 0.5rem; overflow-x: auto; }
    .chat-bubble-ai code { background: rgba(0,0,0,0.15); padding: 0.1em 0.35em; border-radius: 3px; font-size: 0.85em; }
    .chat-bubble-ai table { width: 100%; font-size: 0.82rem; }
    .chat-bubble-ai blockquote { border-left: 3px solid #8FD9FB; padding-left: 0.75rem; color: #6c757d; }

    /* Typing indicator */
    .typing-indicator { display: flex; gap: 4px; padding: 4px 0; }
    .typing-dot { width: 7px; height: 7px; border-radius: 50%; background: #6c757d; animation: typingBounce 1.2s infinite; }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes typingBounce { 0%,80%,100% { transform: scale(0.7); opacity: 0.5; } 40% { transform: scale(1); opacity: 1; } }

    /* Sidebar search input placeholder */
    #sessionSearch::placeholder { color: rgba(255,255,255,0.35); }
    #sessionSearch:focus { background: rgba(255,255,255,0.12) !important; color: #fff !important; box-shadow: none; outline: none; }
</style>
}

