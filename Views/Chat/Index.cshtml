    // ── Connect Data Source / UserDataSource Wizard ───────────────────────────

    // State for the wizard
    let dsWizardState = {
        step: 1,
        providerType: null,
        providerName: null,
        connectionString: null,
        connectionName: null,
        fileToUpload: null,
        savedSourceId: null,
        availableTables: [],
        selectedTables: []
    };

    // Open the modal and load the list of data sources
    window.connectDataSource = async function() {
        const modal = new bootstrap.Modal(document.getElementById('dataSourceModal'));
        modal.show();
        await loadUserDataSources();
    };

    async function loadUserDataSources() {
        const container = document.getElementById('userDataSourcesList');
        if (!container) return;
        container.innerHTML = '<div class="text-center text-muted py-3"><div class="spinner-border spinner-border-sm me-2" role="status"></div>Loading...</div>';
        try {
            const res = await fetch('/DataConnection/GetUserSources');
            const result = await res.json();
            if (!result.success) { container.innerHTML = '<div class="text-muted small">Failed to load data sources.</div>'; return; }
            const sources = result.sources || [];
            if (sources.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-4"><i class="bi bi-database fs-3 d-block mb-2"></i><p class="small mb-0">No data sources connected yet.</p></div>';
                return;
            }
            container.innerHTML = sources.map(s => {
                const statusColor = s.status === 'Active' ? '#28a745' : s.status === 'Error' ? '#dc3545' : '#ffc107';
                const badgeBg = s.status === 'Active' ? '#d4edda' : s.status === 'Error' ? '#f8d7da' : '#fff3cd';
                const badgeColor = s.status === 'Active' ? '#155724' : s.status === 'Error' ? '#721c24' : '#856404';
                return `<div class="d-flex align-items-center gap-3 p-3 mb-2 rounded border">
                    <i class="bi bi-circle-fill" style="color:${statusColor};font-size:0.6rem;flex-shrink:0;"></i>
                    <div class="flex-grow-1 min-width-0">
                        <div class="fw-semibold small text-truncate">${escapeHtml(s.name)}</div>
                        <small class="text-muted">${escapeHtml(s.sourceType)}</small>
                    </div>
                    <span class="badge" style="background:${badgeBg};color:${badgeColor};font-size:0.7rem;">${escapeHtml(s.status)}</span>
                    <button class="btn btn-sm btn-outline-danger" style="font-size:0.7rem;" onclick="deleteUserDataSource(${s.id})" title="Delete">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>`;
            }).join('');
        } catch(e) {
            container.innerHTML = '<div class="text-muted small">Could not load data sources.</div>';
        }
    }

    async function deleteUserDataSource(id) {
        if (!confirm('Delete this data source?')) return;
        try {
            const res = await fetch('/DataConnection/Delete', {
                method: 'POST',
                headers: { 'RequestVerificationToken': getAntiForgeryToken(), 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}`
            });
            await loadUserDataSources();
        } catch(e) { showToast('Failed to delete data source.', 'danger'); }
    }
    window.deleteUserDataSource = deleteUserDataSource;

    function startDsWizard() {
        dsWizardState = { step: 1, providerType: null, providerName: null, connectionString: null, connectionName: null, fileToUpload: null, savedSourceId: null, availableTables: [], selectedTables: [] };
        document.getElementById('dsListView').style.display = 'none';
        document.getElementById('dsWizardView').style.display = '';
        dsGoToStep(1);
    }
    window.startDsWizard = startDsWizard;

    function cancelDsWizard() {
        document.getElementById('dsWizardView').style.display = 'none';
        document.getElementById('dsListView').style.display = '';
    }
    window.cancelDsWizard = cancelDsWizard;

    function dsGoToStep(step) {
        dsWizardState.step = step;
        [1,2,3,4].forEach(s => {
            const el = document.getElementById('dsStep' + s);
            if (el) el.style.display = (s === step) ? '' : 'none';
        });
        document.querySelectorAll('#dsWizardSteps .wizard-step').forEach(el => {
            const s = parseInt(el.getAttribute('data-step'));
            el.classList.toggle('active', s === step);
            el.classList.toggle('done', s < step);
        });
    }
    window.dsGoToStep = dsGoToStep;

    function dsSelectProvider(type, name) {
        dsWizardState.providerType = type;
        dsWizardState.providerName = name;
        document.querySelectorAll('.ds-provider-card').forEach(c => c.classList.remove('selected'));
        event.currentTarget.classList.add('selected');
        renderDsDetailsForm(type, name);
        dsGoToStep(2);
    }
    window.dsSelectProvider = dsSelectProvider;

    function renderDsDetailsForm(type, name) {
        const container = document.getElementById('dsStep2Form');
        let html = `<div class="mb-3"><label class="form-label fw-semibold">Connection Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="dsConnName" placeholder="e.g. Production DB" required></div>`;

        if (type === 'Excel' || type === 'CSV') {
            html += `<div class="mb-3"><label class="form-label fw-semibold">Upload File <span class="text-danger">*</span></label>
                <input type="file" class="form-control" id="dsFileInput" accept=".xlsx,.xls,.csv" onchange="dsFileSelected()">
                <small class="text-muted">Supported: .xlsx, .xls, .csv (max 50 MB)</small></div>`;
        } else {
            const rawConnStr = type === 'MongoDB' || type === 'Elasticsearch' || type === 'Redis';
            if (rawConnStr) {
                const placeholder = type === 'MongoDB' ? 'mongodb://user:pass@host:27017/dbname'
                    : type === 'Elasticsearch' ? 'http://localhost:9200'
                    : 'localhost:6379,password=xxx';
                html += `<div class="mb-3"><label class="form-label fw-semibold">Connection URI <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="dsConnStr" placeholder="${escapeHtml(placeholder)}" required></div>`;
            } else {
                html += `<div class="row g-3 mb-3">
                    <div class="col-sm-8"><label class="form-label">Server / Host <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="dsHost" placeholder="e.g. localhost" required></div>
                    <div class="col-sm-4"><label class="form-label">Port</label>
                        <input type="number" class="form-control" id="dsPort" placeholder="${type === 'PostgreSQL' ? '5432' : type === 'MySQL' ? '3306' : '1433'}"></div>
                </div>
                <div class="mb-3"><label class="form-label">Database <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="dsDatabase" placeholder="Database name" required></div>
                <div class="row g-3 mb-3">
                    <div class="col-sm-6"><label class="form-label">Username</label>
                        <input type="text" class="form-control" id="dsUser" autocomplete="username"></div>
                    <div class="col-sm-6"><label class="form-label">Password</label>
                        <input type="password" class="form-control" id="dsPassword" autocomplete="current-password"></div>
                </div>
                <details class="mb-3"><summary class="text-muted small" style="cursor:pointer;">Or paste a raw connection string</summary>
                    <div class="mt-2"><textarea class="form-control" id="dsConnStr" rows="2" placeholder="Server=..."></textarea></div>
                </details>`;
            }
        }
        container.innerHTML = html;
        document.getElementById('dsNextStep2Btn').disabled = true;
        document.getElementById('dsTestResult').innerHTML = '';
    }

    function dsFileSelected() {
        const file = document.getElementById('dsFileInput')?.files?.[0];
        dsWizardState.fileToUpload = file || null;
        document.getElementById('dsNextStep2Btn').disabled = !file;
        document.getElementById('dsTestResult').innerHTML = file
            ? '<div class="alert alert-success small py-2 mb-0"><i class="bi bi-check-circle me-1"></i>File ready to upload.</div>'
            : '';
    }
    window.dsFileSelected = dsFileSelected;

    function dsBuildConnectionString() {
        const type = dsWizardState.providerType;
        if (type === 'Excel' || type === 'CSV') return null;
        const rawField = document.getElementById('dsConnStr');
        if (rawField && rawField.value.trim()) return rawField.value.trim();
        const host = document.getElementById('dsHost')?.value?.trim() || '';
        const port = document.getElementById('dsPort')?.value?.trim() || '';
        const db = document.getElementById('dsDatabase')?.value?.trim() || '';
        const user = document.getElementById('dsUser')?.value?.trim() || '';
        const pass = document.getElementById('dsPassword')?.value || '';
        if (!host || !db) return null;
        if (type === 'PostgreSQL') return `Host=${host};${port ? 'Port=' + port + ';' : ''}Database=${db};Username=${user};Password=${pass};`;
        if (type === 'MySQL')      return `Server=${host};${port ? 'Port=' + port + ';' : ''}Database=${db};User Id=${user};Password=${pass};`;
        return `Server=${host}${port ? ',' + port : ''};Database=${db};User Id=${user};Password=${pass};Encrypt=True;TrustServerCertificate=True;`;
    }

    async function dsTestConnection() {
        const name = document.getElementById('dsConnName')?.value?.trim();
        if (!name) { showToast('Please enter a connection name first.', 'warning'); return; }
        const type = dsWizardState.providerType;
        const connStr = dsBuildConnectionString();
        if (!connStr) { showToast('Please fill in the required connection fields.', 'warning'); return; }
        dsWizardState.connectionString = connStr;
        dsWizardState.connectionName = name;

        const btn = document.getElementById('dsTestBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Testing...';

        try {
            const res = await fetch('/DataConnection/TestConnection', {
                method: 'POST',
                headers: { 'RequestVerificationToken': getAntiForgeryToken(), 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ sourceType: type, connectionString: connStr })
            });
            const result = await res.json();
            const el = document.getElementById('dsTestResult');
            if (result.success) {
                el.innerHTML = '<div class="alert alert-success small py-2 mb-0"><i class="bi bi-check-circle me-1"></i>Connection successful!</div>';
                document.getElementById('dsNextStep2Btn').disabled = false;
            } else {
                el.innerHTML = `<div class="alert alert-danger small py-2 mb-0"><i class="bi bi-x-circle me-1"></i>${escapeHtml(result.message || 'Connection failed.')}</div>`;
            }
        } catch(e) {
            document.getElementById('dsTestResult').innerHTML = '<div class="alert alert-danger small py-2 mb-0">Error testing connection.</div>';
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-plug me-1"></i>Test Connection';
        }
    }
    window.dsTestConnection = dsTestConnection;

    async function dsProceedToTables() {
        const name = document.getElementById('dsConnName')?.value?.trim();
        dsWizardState.connectionName = name;
        const type = dsWizardState.providerType;
        if (type === 'Excel' || type === 'CSV') {
            dsGoToStep(4);
            renderDsConfirmSummary();
            return;
        }
        dsGoToStep(3);
        const tablesList = document.getElementById('dsTablesList');
        tablesList.innerHTML = '<div class="col-12 text-center text-muted py-2"><div class="spinner-border spinner-border-sm me-1"></div>Fetching tables...</div>';
        try {
            const res = await fetch(`/DataConnection/GetTables?sourceType=${encodeURIComponent(type)}&connectionString=${encodeURIComponent(dsWizardState.connectionString)}`);
            const result = await res.json();
            if (result.success && result.tables?.length > 0) {
                dsWizardState.availableTables = result.tables;
                tablesList.innerHTML = result.tables.map(t => `
                    <div class="col-sm-6 col-md-4">
                        <div class="form-check">
                            <input class="form-check-input ds-table-check" type="checkbox" value="${escapeHtml(t)}" id="dst_${escapeHtml(t)}" checked>
                            <label class="form-check-label small" for="dst_${escapeHtml(t)}">${escapeHtml(t)}</label>
                        </div>
                    </div>`).join('');
            } else {
                tablesList.innerHTML = '<div class="col-12 text-muted small">No tables found or unable to fetch tables.</div>';
            }
        } catch(e) {
            tablesList.innerHTML = '<div class="col-12 text-muted small">Failed to fetch tables.</div>';
        }
    }
    window.dsProceedToTables = dsProceedToTables;

    function dsProceedToConfirm() {
        const checked = Array.from(document.querySelectorAll('.ds-table-check:checked')).map(c => c.value);
        dsWizardState.selectedTables = checked;
        dsGoToStep(4);
        renderDsConfirmSummary();
    }
    window.dsProceedToConfirm = dsProceedToConfirm;

    function renderDsConfirmSummary() {
        const el = document.getElementById('dsConfirmSummary');
        const tables = dsWizardState.selectedTables;
        el.innerHTML = `<strong>${escapeHtml(dsWizardState.connectionName)}</strong><br>
            Type: <strong>${escapeHtml(dsWizardState.providerName)}</strong><br>
            ${tables.length > 0 ? 'Tables: <strong>' + tables.map(escapeHtml).join(', ') + '</strong>' : ''}`;
    }

    async function dsFinish() {
        const btn = document.getElementById('dsFinishBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
        try {
            const type = dsWizardState.providerType;
            let response;
            if (type === 'Excel' || type === 'CSV') {
                const formData = new FormData();
                formData.append('Name', dsWizardState.connectionName);
                formData.append('SourceType', type);
                formData.append('File', dsWizardState.fileToUpload);
                formData.append('__RequestVerificationToken', getAntiForgeryToken());
                response = await fetch('/DataConnection/UploadFile', { method: 'POST', body: formData });
            } else {
                response = await fetch('/DataConnection/ConnectDatabase', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': getAntiForgeryToken(), 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ Name: dsWizardState.connectionName, SourceType: type, ConnectionString: dsWizardState.connectionString })
                });
            }

            if (response.redirected || response.ok) {
                if (dsWizardState.savedSourceId && dsWizardState.selectedTables.length > 0) {
                    await fetch('/DataConnection/UpdateTables?id=' + dsWizardState.savedSourceId, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': getAntiForgeryToken(), 'Content-Type': 'application/json' },
                        body: JSON.stringify(dsWizardState.selectedTables)
                    });
                }
                showToast('Data source connected successfully!', 'success');
                cancelDsWizard();
                await loadUserDataSources();
            } else {
                showToast('Failed to save data source. Please try again.', 'danger');
            }
        } catch(e) {
            showToast('Error saving data source: ' + e.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-check-circle me-1"></i>Finish';
        }
    }
    window.dsFinish = dsFinish;

    // ── Edit Workspace (Placeholder) ───────────────────────────────────────
    function editWorkspace(id) {
        showToast('Workspace editing feature coming soon!', 'info');
        // TODO: Open modal to edit workspace name, description, context
    }

    // ══════════════════════════════════════════════════════════════════════
    // Make all functions globally accessible for inline event handlers
    // ══════════════════════════════════════════════════════════════════════

    // Organization functions
    window.createOrganization = createOrganization;
    window.openOrgMemberModal = openOrgMemberModal;
    window.addOrgMember = addOrgMember;
    window.setActiveOrganization = setActiveOrganization;
    window.loadOrganizations = loadOrganizations;

    // Workspace functions
    window.createWorkspace = createWorkspace;
    window.deleteWorkspace = deleteWorkspace;
    window.editWorkspace = editWorkspace;
    window.loadWorkspaces = loadWorkspaces;

    // Agent functions
    window.selectAgent = selectAgent;
    window.shareAgent = shareAgent;
    window.generateAgentEmbed = generateAgentEmbed;
    window.copyShareLink = copyShareLink;
    window.copyEmbedCode = copyEmbedCode;
    window.previewAgentEmbed = previewAgentEmbed;
    window.openAgentModal = openAgentModal;
    window.createAgent = createAgent;
    window.toggleAgentActive = toggleAgentActive;
    window.deleteAgent = deleteAgent;
    window.loadAgents = loadAgents;
    window.loadAvailableAgents = loadAvailableAgents;

    // Team functions
    window.createTeam = createTeam;
    window.openAddMemberModal = openAddMemberModal;
    window.addTeamMember = addTeamMember;
    window.editTeam = editTeam;
    window.updateTeam = updateTeam;
    window.deleteTeam = deleteTeam;
    window.manageTeamWorkspaces = manageTeamWorkspaces;
    window.loadTeams = loadTeams;

    // Embed functions
    window.generateEmbedToken = generateEmbedToken;
    window.copyEmbedToken = copyEmbedToken;
    window.copyIframeCode = copyIframeCode;

    // Data source connection functions
    window.connectDataSource = connectDataSource;
    window.startDsWizard = startDsWizard;
    window.cancelDsWizard = cancelDsWizard;
    window.dsGoToStep = dsGoToStep;
    window.dsSelectProvider = dsSelectProvider;
    window.dsTestConnection = dsTestConnection;
    window.dsProceedToTables = dsProceedToTables;
    window.dsProceedToConfirm = dsProceedToConfirm;
    window.dsFinish = dsFinish;
    window.deleteUserDataSource = deleteUserDataSource;
    window.dsFileSelected = dsFileSelected;

    // UI/Toast/Modal functions
    window.showToast = showToast;
    window.showConfirmModal = showConfirmModal;
    window.executeConfirmedAction = executeConfirmedAction;
    window.confirmClearAllSessions = confirmClearAllSessions;
    window.copyToClipboard = copyToClipboard;

    // Utility functions (also used by chat.js)
    window.escapeHtml = escapeHtml;
    window.getAntiForgeryToken = getAntiForgeryToken;

    // ══════════════════════════════════════════════════════════════════════
    // Note: The following functions are defined in chat.js and should be
    // made globally accessible there if needed for inline handlers:
    // - newChat(), clearChat(), exportAsPDF(), toggleRightPanel()
    // - triggerFileAttach(), handleFileSelected(), handleKeyDown()
    // - toggleMic(), sendMessage(), appendMessage()
    // ══════════════════════════════════════════════════════════════════════
</script>
