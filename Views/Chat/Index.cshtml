@model ChatPortal.ViewModels.ChatViewModel
@{
    ViewData["Title"] = "Chat";
    ViewData["MetaDescription"] = "Chat with ChatPortal AI — your intelligent assistant for code, writing, analysis, and more.";
    ViewData["MetaKeywords"] = "AI chat, ChatPortal, GPT, assistant, code help, writing";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="chat-layout d-flex position-relative" style="height:calc(100vh - 56px);overflow:hidden;">

    <!-- ── Left Sidebar: Navigation & Management ── -->
    <div class="chat-sidebar d-flex flex-column border-end" style="width:280px;flex-shrink:0;background:linear-gradient(180deg,#f8f9fa 0%,#e8eaf6 100%);">

        <!-- New Chat Button -->
        <div class="p-3 border-bottom">
            <button class="btn w-100 shadow-sm" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;font-weight:600;" onclick="openNewChatModal()">
                <i class="bi bi-plus-lg me-2"></i>New Chat
            </button>
        </div>

        <!-- Navigation Sections -->
        <div class="flex-grow-1 overflow-auto">

            <!-- Organization Management Section -->
            <div class="p-3 border-bottom">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <label class="text-secondary mb-0" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">Organization</label>
                    <button class="btn btn-sm" style="color:#667eea;padding:0;" title="Manage Organizations" data-bs-toggle="modal" data-bs-target="#organizationManagementModal">
                        <i class="bi bi-gear"></i>
                    </button>
                </div>
                <div class="dropdown w-100">
                    <button class="btn btn-sm w-100 text-start d-flex align-items-center justify-content-between bg-white border shadow-sm"
                            type="button" data-bs-toggle="dropdown" style="color:#2d3748;">
                        <span><i class="bi bi-building me-2" style="color:#667eea;font-size:0.8rem;"></i><span id="activeOrgName">My Organization</span></span>
                        <i class="bi bi-chevron-down" style="font-size:0.7rem;color:#667eea;"></i>
                    </button>
                    <ul class="dropdown-menu w-100 shadow border-0" id="organizationDropdown">
                        <li>
                            <a class="dropdown-item org-option active-org d-flex align-items-center gap-2" href="#" data-org="My Organization">
                                <i class="bi bi-building" style="color:#667eea;font-size:0.8rem;"></i>
                                <div>
                                    <div style="font-size:0.85rem;color:#2d3748;">My Organization</div>
                                    <div class="text-muted" style="font-size:0.7rem;">Owner</div>
                                </div>
                            </a>
                        </li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2" href="#" data-bs-toggle="modal" data-bs-target="#organizationManagementModal" style="font-size:0.82rem;color:#667eea;">
                                <i class="bi bi-gear me-1"></i>Manage Organization
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Team Management Section -->
            <div class="p-3 border-bottom">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <label class="text-secondary mb-0" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">Teams</label>
                    <button class="btn btn-sm" style="color:#667eea;padding:0;" title="Manage Teams" data-bs-toggle="modal" data-bs-target="#teamManagementModal">
                        <i class="bi bi-gear"></i>
                    </button>
                </div>
                <div class="dropdown w-100">
                    <button class="btn btn-sm w-100 text-start d-flex align-items-center justify-content-between bg-white border shadow-sm"
                            type="button" data-bs-toggle="dropdown" style="color:#2d3748;">
                        <span><i class="bi bi-people-fill me-2" style="color:#667eea;font-size:0.8rem;"></i><span id="activeTeamName">Personal Team</span></span>
                        <i class="bi bi-chevron-down" style="font-size:0.7rem;color:#667eea;"></i>
                    </button>
                    <ul class="dropdown-menu w-100 shadow border-0">
                        <li>
                            <a class="dropdown-item team-option active-team d-flex align-items-center gap-2" href="#" data-team="Personal Team">
                                <i class="bi bi-people-fill" style="color:#667eea;font-size:0.8rem;"></i>
                                <div>
                                    <div style="font-size:0.85rem;color:#2d3748;">Personal Team</div>
                                    <div class="text-muted" style="font-size:0.7rem;">Private workspace</div>
                                </div>
                            </a>
                        </li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2" href="#" data-bs-toggle="modal" data-bs-target="#teamManagementModal" style="font-size:0.82rem;color:#667eea;">
                                <i class="bi bi-plus-circle me-1"></i>Create Team
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Workspace Management Section -->
            <div class="p-3 border-bottom">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <label class="text-secondary mb-0" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">Workspaces</label>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm" style="color:#667eea;padding:0;" title="Manage AI Agents" data-bs-toggle="modal" data-bs-target="#agentManagementModal">
                            <i class="bi bi-robot"></i>
                        </button>
                        <button class="btn btn-sm" style="color:#764ba2;padding:0;" title="Manage Workspaces" data-bs-toggle="modal" data-bs-target="#workspaceManagementModal">
                            <i class="bi bi-gear"></i>
                        </button>
                    </div>
                </div>
                <div class="dropdown w-100">
                    <button class="btn btn-sm w-100 text-start d-flex align-items-center justify-content-between bg-white border shadow-sm"
                            type="button" data-bs-toggle="dropdown" style="color:#2d3748;">
                        <span><i class="bi bi-grid-fill me-2" style="color:#764ba2;font-size:0.8rem;"></i><span id="activeWorkspaceName">General Workspace</span></span>
                        <i class="bi bi-chevron-down" style="font-size:0.7rem;color:#764ba2;"></i>
                    </button>
                    <ul class="dropdown-menu w-100 shadow border-0" id="workspaceDropdown">
                        <li>
                            <a class="dropdown-item workspace-option active-workspace d-flex align-items-center gap-2" href="#" data-workspace="General Workspace">
                                <i class="bi bi-grid-fill" style="color:#764ba2;font-size:0.8rem;"></i>
                                <div>
                                    <div style="font-size:0.85rem;color:#2d3748;">General Workspace</div>
                                    <div class="text-muted" style="font-size:0.7rem;">General Purpose Agent</div>
                                </div>
                            </a>
                        </li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2" href="#" data-bs-toggle="modal" data-bs-target="#agentManagementModal" style="font-size:0.82rem;color:#667eea;">
                                <i class="bi bi-robot me-1"></i>Manage AI Agents
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item d-flex align-items-center gap-2" href="#" data-bs-toggle="modal" data-bs-target="#workspaceManagementModal" style="font-size:0.82rem;color:#764ba2;">
                                <i class="bi bi-plus-circle me-1"></i>Create Workspace
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- My Data Section -->
            <div class="p-3 border-bottom">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <label class="text-secondary mb-0" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">My Data</label>
                    <button class="btn btn-sm" style="color:#667eea;padding:0;" title="Manage Data Sources" onclick="connectDataSource()">
                        <i class="bi bi-gear"></i>
                    </button>
                </div>
                <div class="small text-muted mb-2" data-datasource-status>
                    @if (Model.DataSources.Count > 0)
                    {
                        var activeCount = Model.DataSources.Count(d => d.Status == "Active");
                        <div class="d-flex align-items-center gap-2 mb-1" style="font-size:0.8rem;">
                            <i class="bi bi-database" style="color:#667eea;"></i>
                            <span>@activeCount of @Model.DataSources.Count active</span>
                        </div>
                        foreach (var ds in Model.DataSources.Take(3))
                        {
                            var iconColor = ds.Status == "Active" ? "#28a745" : ds.Status == "Error" ? "#dc3545" : "#ffc107";
                            <div class="d-flex align-items-center gap-2 py-1 px-2 rounded mb-1" style="background:#f8f9fa;font-size:0.78rem;">
                                <i class="bi bi-circle-fill" style="color:@iconColor;font-size:0.5rem;"></i>
                                <span class="text-truncate flex-grow-1" title="@ds.Name">@ds.Name</span>
                                <span class="badge badge-sm" style="font-size:0.65rem;background:@(ds.Status == "Active" ? "#d4edda" : ds.Status == "Error" ? "#f8d7da" : "#fff3cd");color:@(ds.Status == "Active" ? "#155724" : ds.Status == "Error" ? "#721c24" : "#856404");">@ds.Status</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2 mb-1" style="font-size:0.8rem;">
                            <i class="bi bi-database" style="color:#667eea;"></i>
                            <span>No data sources connected</span>
                        </div>
                    }
                </div>
                <button class="btn btn-sm btn-outline-secondary w-100" style="font-size:0.75rem;" onclick="connectDataSource()">
                    <i class="bi bi-plus-circle me-1"></i>Connect Data Source
                </button>
            </div>

            <!-- Conversation History Section -->
            <div class="p-3">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <label class="text-secondary mb-0" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">Conversations</label>
                    <button class="btn btn-sm" style="color:#e74c3c;padding:0;" title="Clear All Sessions" onclick="confirmClearAllSessions()">
                        <i class="bi bi-trash3"></i>
                    </button>
                </div>
                <div class="input-group input-group-sm mb-3">
                    <span class="input-group-text bg-white border"><i class="bi bi-search" style="color:#667eea;"></i></span>
                    <input type="text" id="sessionSearch" class="form-control bg-white border shadow-none"
                           placeholder="Search…" style="font-size:0.8rem;color:#2d3748;">
                </div>
                <div id="sessionList">
                    <!-- Rendered by chatHistory.js -->
                </div>
            </div>
        </div>

        <!-- User Info -->
        <div class="p-3 border-top" style="background:#fff;">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:32px;height:32px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                    <i class="bi bi-person" style="color:white;font-size:0.9rem;"></i>
                </div>
                <div class="overflow-hidden flex-grow-1">
                    <div class="small fw-medium text-truncate" style="color:#2d3748;">Demo User</div>
                    <div class="text-muted" style="font-size:0.7rem;">Free Plan</div>
                </div>
                <a href="/Account/Settings" style="color:#667eea;font-size:0.85rem;" title="Settings">
                    <i class="bi bi-gear"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- ── Central Chat Area ── -->
    <div class="chat-main flex-grow-1 d-flex flex-column" style="min-width:0;background:#fafafa;">
        <!-- Chat Header -->
        <div class="chat-header d-flex align-items-center justify-content-between p-3 border-bottom bg-white shadow-sm">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:40px;height:40px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                    <i class="bi bi-robot" style="color:white;font-size:1.1rem;"></i>
                </div>
                <div>
                    <div class="fw-medium" style="color:#2d3748;" id="selectedAgentName">No Agent Selected</div>
                    <div class="small" id="agentStatus" style="color:#e74c3c;">
                        <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Select an agent to start
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <!-- Agent Selector -->
                <select id="agentSelect" class="form-select form-select-sm" style="width:200px;" onchange="selectAgent()">
                    <option value="">-- Select AI Agent --</option>
                </select>
                <select id="modelSelect" class="form-select form-select-sm" style="width:auto;">
                    @foreach (var aiModel in Model.AvailableModels)
                    {
                        <option value="@aiModel" selected="@(aiModel == Model.SelectedModel)">@aiModel</option>
                    }
                </select>
                <!-- Share Agent -->
                <button class="btn btn-sm btn-outline-secondary" id="shareAgentBtn" title="Share Agent" onclick="shareAgent()" disabled>
                    <i class="bi bi-share"></i>
                </button>
                <!-- Export as iframe -->
                <button class="btn btn-sm btn-outline-secondary" id="exportAgentBtn" title="Export Agent as iframe" 
                        data-bs-toggle="modal" data-bs-target="#embedAgentModal" disabled>
                    <i class="bi bi-code-slash"></i>
                </button>
                <!-- Export PDF -->
                <button class="btn btn-sm btn-outline-secondary" title="Export as PDF" onclick="exportAsPDF()">
                    <i class="bi bi-file-earmark-pdf"></i>
                </button>
                <!-- Toggle Right Panel -->
                <button class="btn btn-sm btn-outline-secondary" id="togglePanelBtn" title="Source references" onclick="toggleRightPanel()">
                    <i class="bi bi-layout-sidebar-reverse"></i>
                </button>
                <!-- Clear Chat -->
                <button class="btn btn-sm btn-outline-secondary" title="Clear chat" onclick="clearChat()">
                    <i class="bi bi-trash3"></i>
                </button>
            </div>
        </div>

        <!-- Messages -->
        <div class="chat-messages flex-grow-1 overflow-auto p-4" id="chatMessages">
            <!-- Messages rendered by JS / chatHistory.js -->
        </div>

        <!-- File Attachment Chip -->
        <div id="attachmentChip" class="px-3 pt-2" style="display:none;"></div>

        <!-- Input Area -->
        <div class="chat-input-area p-3 border-top bg-white shadow-sm">
            <div class="container-lg">
                @Html.AntiForgeryToken()
                <div class="input-group shadow-sm rounded-3 overflow-hidden border">
                    <!-- Hidden file input -->
                    <input type="file" id="fileInput" class="d-none" accept=".txt,.csv,.json,.pdf"
                           onchange="handleFileSelected(event)" />
                    <!-- Attach button -->
                    <button class="btn btn-outline-secondary border-0 px-3" type="button"
                            title="Attach file (.txt, .csv, .json, .pdf)" onclick="triggerFileAttach()">
                        <i class="bi bi-paperclip"></i>
                    </button>
                    <textarea id="messageInput" class="form-control border-0 shadow-none"
                              placeholder="Select an AI agent above to start chatting…" rows="1"
                              style="resize:none;max-height:200px;"
                              onkeydown="handleKeyDown(event)" disabled></textarea>
                    <button class="btn btn-outline-secondary border-0 px-3" id="micBtn" type="button"
                            title="Voice input (Web Speech API)" onclick="toggleMic()">
                        <i class="bi bi-mic-fill" id="micIcon"></i>
                    </button>
                    <button class="btn px-4" id="sendBtn" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;border:none;" onclick="sendMessage()" disabled>
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
                <div class="text-center mt-2">
                    <small class="text-muted">ChatPortal AI may produce inaccurate results. <a href="/pages/docs" class="text-muted">Learn more</a></small>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Right Panel: Source References ── -->
    <div id="rightPanel" class="chat-right-panel bg-white border-start d-flex flex-column"
         style="width:300px;flex-shrink:0;transition:width 0.25s ease,opacity 0.25s ease;overflow:hidden;opacity:0;width:0;">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <span class="small fw-semibold text-uppercase text-secondary">Source References</span>
            <button class="btn btn-sm border-0 p-0" onclick="toggleRightPanel()" title="Close panel" style="color:#667eea;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="flex-grow-1 overflow-auto" id="rightPanelContent">
            <div class="text-center text-muted py-5 px-3">
                <i class="bi bi-database fs-3 mb-2 d-block opacity-25" style="color:#667eea;"></i>
                <p class="small">Data references from AI responses will appear here.</p>
            </div>
        </div>
    </div>
</div>

<!-- ── Organization Management Modal ── -->
<div class="modal fade" id="organizationManagementModal" tabindex="-1" aria-labelledby="organizationManagementLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-2" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                <h5 class="modal-title fw-bold text-white" id="organizationManagementLabel">
                    <i class="bi bi-building me-2"></i>Organization Management
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4" id="createOrgSection">
                    <h6 class="fw-bold mb-3">Create Your Organization</h6>
                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle me-1"></i>Each user can create one organization. You can invite members to join your organization.
                    </div>
                    <form id="createOrganizationForm" onsubmit="createOrganization(event)">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6">
                                <input type="text" class="form-control" placeholder="Organization Name" id="orgName" name="name" required />
                            </div>
                            <div class="col-md-6">
                                <input type="text" class="form-control" placeholder="Industry (optional)" id="orgIndustry" name="industry" />
                            </div>
                            <div class="col-12">
                                <textarea class="form-control" placeholder="Description (optional)" id="orgDescription" name="description" rows="2"></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;">
                                    <i class="bi bi-plus-circle me-1"></i>Create Organization
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
                <hr id="orgDivider" />
                <div>
                    <h6 class="fw-bold mb-3">Your Organization</h6>
                    <div id="organizationsList" class="list-group">
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-building fs-2"></i>
                            <p class="small mb-0">Loading organization...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Team Management Modal ── -->
<div class="modal fade" id="teamManagementModal" tabindex="-1" aria-labelledby="teamManagementLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-2" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                <h5 class="modal-title fw-bold text-white" id="teamManagementLabel">
                    <i class="bi bi-people-fill me-2"></i>Team Management
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Create New Team</h6>
                    <form id="createTeamForm" onsubmit="createTeam(event)">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6">
                                <input type="text" class="form-control" placeholder="Team Name" id="teamName" name="name" required />
                            </div>
                            <div class="col-md-6">
                                <input type="text" class="form-control" placeholder="Description" id="teamDescription" name="description" />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;">
                                    <i class="bi bi-plus-circle me-1"></i>Create Team
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
                <hr />
                <div>
                    <h6 class="fw-bold mb-3">Your Teams</h6>
                    <div id="teamsList" class="list-group">
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-people-fill fs-2"></i>
                            <p class="small mb-0">Loading teams...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Workspace Management Modal ── -->
<div class="modal fade" id="workspaceManagementModal" tabindex="-1" aria-labelledby="workspaceManagementLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-2" style="background:linear-gradient(135deg,#764ba2 0%,#667eea 100%);">
                <h5 class="modal-title fw-bold text-white" id="workspaceManagementLabel">
                    <i class="bi bi-grid-fill me-2"></i>Workspace Management
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Create New Workspace</h6>
                    <form id="createWorkspaceForm" onsubmit="createWorkspace(event)">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-4">
                                <input type="text" class="form-control" placeholder="Workspace Name" id="workspaceName" name="name" required />
                            </div>
                            <div class="col-md-4">
                                <select class="form-select" id="workspaceContext" name="context">
                                    <option value="general">General Purpose</option>
                                    <option value="code">Code Assistant</option>
                                    <option value="writing">Writing Helper</option>
                                    <option value="data">Data Analysis</option>
                                    <option value="research">Research</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <select class="form-select" id="workspaceTeam" name="teamId">
                                    <option value="">None</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <textarea class="form-control" placeholder="Description (optional)" id="workspaceDesc" name="description" rows="2"></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm" style="background:linear-gradient(135deg,#764ba2 0%,#667eea 100%);color:white;">
                                    <i class="bi bi-plus-circle me-1"></i>Create Workspace
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
                <hr />
                <div>
                    <h6 class="fw-bold mb-3">Your Workspaces</h6>
                    <div id="workspacesList" class="list-group">
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-medium">General Workspace</div>
                                <small class="text-muted">General Purpose Agent - Active</small>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
