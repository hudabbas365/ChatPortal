                    const response = await fetch('/Team/Delete', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                        },
                        body: `id=${id}`
                    });

                    const result = await response.json();
                    if (result.success) {
                        showToast('Team deleted successfully!', 'success');
                        loadTeams();
                    } else {
                        showToast('Error: ' + result.error, 'danger');
                    }
                } catch (error) {
                    showToast('Failed to delete team: ' + error.message, 'danger');
                }
            }
        );
    }

    function manageTeamWorkspaces(teamId, teamName) {
        showToast('Team Workspace Permissions feature coming soon!', 'info');
        // TODO: Open modal showing workspaces with grant/revoke buttons
    }

    // Load teams when page loads
    document.addEventListener('DOMContentLoaded', function() {
        loadTeams();
    });

    // ── Agent embed helpers ───────────────────────────────────────────────
    async function generateEmbedToken() {
        const btn = document.getElementById('generateEmbedTokenBtn');
        const status = document.getElementById('embedTokenStatus');
        btn.disabled = true;
        status.textContent = 'Generating\u2026';
        try {
            const resp = await fetch('/Account/GenerateEmbedToken', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                }
            });
            const data = await resp.json();
            if (data.success && data.token) {
                const origin = window.location.origin;
                const iframeUrl = `${origin}/Embed/Chat?token=${encodeURIComponent(data.token)}`;
                document.getElementById('embedTokenDisplay').value = data.token;
                document.getElementById('embedIframeCode').value =
                    `<iframe src="${iframeUrl}" width="400" height="600" frameborder="0" allow="microphone"></iframe>`;
                document.getElementById('embedCodeSection').classList.remove('d-none');
                status.textContent = '';
            } else {
                status.textContent = data.error || 'Failed to generate token.';
            }
        } catch {
            status.textContent = 'Request failed. Please try again.';
        } finally {
            btn.disabled = false;
        }
    }

    function copyEmbedToken() {
        const el = document.getElementById('embedTokenDisplay');
        navigator.clipboard?.writeText(el.value).catch(() => { el.select(); document.execCommand('copy'); });
    }

    function copyIframeCode() {
        const el = document.getElementById('embedIframeCode');
        navigator.clipboard?.writeText(el.value).catch(() => { el.select(); document.execCommand('copy'); });
    }

    // ── Toast Notification System ─────────────────────────────────────────
    function showToast(message, type = 'info') {
        const toastContainer = document.getElementById('toastContainer');
        const toastId = 'toast_' + Date.now();

        const bgColors = {
            success: 'bg-success',
            danger: 'bg-danger',
            warning: 'bg-warning',
            info: 'bg-info'
        };

        const icons = {
            success: 'check-circle-fill',
            danger: 'exclamation-circle-fill',
            warning: 'exclamation-triangle-fill',
            info: 'info-circle-fill'
        };

        const toastHTML = `
            <div class="toast align-items-center text-white ${bgColors[type]} border-0" role="alert" id="${toastId}">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bi bi-${icons[type]}"></i>
                        ${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        `;

        toastContainer.insertAdjacentHTML('beforeend', toastHTML);
        const toastElement = document.getElementById(toastId);
        const toast = new bootstrap.Toast(toastElement, { autohide: true, delay: 3000 });
        toast.show();

        toastElement.addEventListener('hidden.bs.toast', function() {
            toastElement.remove();
        });
    }

    // ── Confirmation Modal System ─────────────────────────────────────────
    let confirmedActionCallback = null;

    function showConfirmModal(title, message, onConfirm) {
        document.getElementById('confirmModalLabel').innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i>${title}`;
        document.getElementById('confirmModalMessage').textContent = message;
        confirmedActionCallback = onConfirm;
        const modal = new bootstrap.Modal(document.getElementById('confirmModal'));
        modal.show();
    }

    async function executeConfirmedAction() {
        if (confirmedActionCallback) {
            bootstrap.Modal.getInstance(document.getElementById('confirmModal')).hide();
            await confirmedActionCallback();
            confirmedActionCallback = null;
        }
    }

    // ── Clear All Sessions ─────────────────────────────────────────────────
    function confirmClearAllSessions() {
        showConfirmModal(
            'Clear All Sessions',
            'Are you sure you want to clear all conversation sessions? This action cannot be undone.',
            () => {
                // Clear from localStorage
                if (typeof clearAllSessions === 'function') {
                    clearAllSessions();
                    showToast('All sessions cleared successfully!', 'success');
                    // Clear UI and create new session
                    renderSidebar();
                    newChat();
                } else {
                    showToast('Session clear functionality not available', 'warning');
                }
            }
        );
    }

    // ── Connect Data Source ─────────────────────────────────────────────────
    let selectedProvider = null;
    let allProviders = {};

    async function connectDataSource() {
        const modal = new bootstrap.Modal(document.getElementById('dataSourceModal'));
        modal.show();

        // Load providers from backend
        await loadProviders();
        displayProviderSelection();
        loadConnectedDataSources();
    }

    async function loadProviders() {
        try {
            const response = await fetch('/DataSource/GetProviders');
            const result = await response.json();

            if (result.success && result.categories) {
                allProviders = {};
                result.categories.forEach(cat => {
                    allProviders[cat.category] = cat.providers;
                });
            }
        } catch (error) {
            console.error('Failed to load providers:', error);
        }
    }

    function displayProviderSelection() {
        const container = document.getElementById('providerSelectionContainer');
        if (!container) return;

        let html = `
            <div class="mb-3">
                <input type="text" class="form-control" id="providerSearch" 
                       placeholder="Search providers..." onkeyup="filterProviders()">
            </div>
            <div id="providerCategoriesContainer">`;

        Object.keys(allProviders).forEach(category => {
            html += `
                <div class="provider-category mb-4">
                    <h6 class="fw-semibold mb-3 text-muted">${category}</h6>
                    <div class="row g-3">`;

            allProviders[category].forEach(provider => {
                html += `
                    <div class="col-md-6 provider-card" data-provider-name="${provider.name.toLowerCase()}" data-provider-id="${provider.id}">
                        <div class="card h-100" style="cursor:pointer;border:2px solid #e2e8f0;transition:all 0.2s;" 
                             onclick="selectProvider('${provider.id}', '${escapeHtml(provider.name)}', '${category}')">
                            <div class="card-body">
                                <div class="d-flex align-items-start gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" 
                                         style="width:48px;height:48px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                                        <i class="bi bi-${provider.icon}" style="color:white;font-size:1.2rem;"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold">${provider.name}</div>
                                        <small class="text-muted">${provider.description}</small>
                                        ${provider.requiresOAuth ? '<div class="badge bg-info mt-1">OAuth Required</div>' : ''}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>`;
            });

            html += `
                    </div>
                </div>`;
        });

        html += '</div>';
        container.innerHTML = html;
    }

    function filterProviders() {
        const searchTerm = document.getElementById('providerSearch').value.toLowerCase();
        const cards = document.querySelectorAll('.provider-card');

        cards.forEach(card => {
            const providerName = card.getAttribute('data-provider-name');
            if (providerName.includes(searchTerm)) {
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function selectProvider(providerId, providerName, category) {
        selectedProvider = { id: providerId, name: providerName, category: category };

        // Highlight selected card
        document.querySelectorAll('.provider-card .card').forEach(card => {
            card.style.borderColor = '#e2e8f0';
            card.style.transform = 'scale(1)';
        });

        const selectedCard = document.querySelector(`[data-provider-id="${providerId}"] .card`);
        if (selectedCard) {
            selectedCard.style.borderColor = '#667eea';
            selectedCard.style.transform = 'scale(1.02)';
        }

        // Show connection form
        showConnectionForm();
    }

    async function showConnectionForm() {
        const container = document.getElementById('connectionFormContainer');
        if (!container || !selectedProvider) return;

        // Get provider schema
        try {
            const response = await fetch(`/DataSource/GetProviderSchema?provider=${selectedProvider.id}`);
            const result = await response.json();

            if (result.success && result.schema) {
                const schema = JSON.parse(result.schema);

                let formHTML = `
                    <div class="alert alert-info">
                        <strong>Connecting to: ${selectedProvider.name}</strong>
                        <button type="button" class="btn-close float-end" onclick="cancelProviderSelection()"></button>
                    </div>
                    <form id="connectionForm" onsubmit="submitConnection(event)">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="provider" value="${selectedProvider.id}">

                        <div class="mb-3">
                            <label class="form-label">Connection Name *</label>
                            <input type="text" class="form-control" name="name" 
                                   placeholder="e.g., Production Database" required>
                        </div>`;

                // Generate form fields based on schema
                Object.keys(schema.properties).forEach(key => {
                    const prop = schema.properties[key];
                    const isRequired = schema.required && schema.required.includes(key);
                    const inputType = prop.format === 'password' ? 'password' : 
                                    prop.type === 'integer' ? 'number' : 'text';

                    formHTML += `
                        <div class="mb-3">
                            <label class="form-label">${key.charAt(0).toUpperCase() + key.slice(1)} ${isRequired ? '*' : ''}</label>
                            <input type="${inputType}" class="form-control" name="${key}" 
                                   placeholder="${prop.description || ''}" 
                                   value="${prop.default || ''}" 
                                   ${isRequired ? 'required' : ''}>
                            ${prop.description ? `<small class="text-muted">${prop.description}</small>` : ''}
                        </div>`;
                });

                formHTML += `
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-secondary" onclick="cancelProviderSelection()">
                                Back to Providers
                            </button>
                            <button type="submit" class="btn btn-primary flex-grow-1" 
                                    style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);border:none;">
                                <i class="bi bi-plug me-1"></i>Test & Connect
                            </button>
                        </div>
                    </form>`;

                container.innerHTML = formHTML;
                container.style.display = 'block';
                document.getElementById('providerSelectionContainer').style.display = 'none';
            }
        } catch (error) {
            showToast('Failed to load connection form', 'danger');
        }
    }

    function cancelProviderSelection() {
        selectedProvider = null;
        document.getElementById('connectionFormContainer').style.display = 'none';
        document.getElementById('providerSelectionContainer').style.display = 'block';

        // Reset card highlights
        document.querySelectorAll('.provider-card .card').forEach(card => {
            card.style.borderColor = '#e2e8f0';
            card.style.transform = 'scale(1)';
        });
    }

    async function submitConnection(event) {
        event.preventDefault();
        const form = event.target;
        const formData = new FormData(form);
        const btn = form.querySelector('button[type="submit"]');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Connecting...';

        try {
            // Build connection string or config based on form data
            const provider = formData.get('provider');
            const name = formData.get('name');

            // For SQL databases, build connection string
            let connectionString = null;
            let apiEndpoint = null;
            let apiKey = null;
            let username = null;
            let password = null;
            let additionalConfig = {};

            // Extract fields based on provider type
            for (let [key, value] of formData.entries()) {
                if (key !== 'provider' && key !== 'name' && key !== '__RequestVerificationToken') {
                    if (key === 'server' || key === 'host') {
                        username = formData.get('username');
                        password = formData.get('password');
                        const db = formData.get('database');
                        const port = formData.get('port');

                        // Build connection string for SQL databases
                        if (provider.includes('sql') || provider.includes('mysql') || provider.includes('postgre')) {
                            if (provider === 'mysql') {
                                connectionString = `Server=${value};${port ? `Port=${port};` : ''}Database=${db};User Id=${username};Password=${password};`;
                            } else if (provider === 'postgresql') {
                                connectionString = `Host=${value};${port ? `Port=${port};` : ''}Database=${db};Username=${username};Password=${password};`;
                            } else {
                                connectionString = `Server=${value};Database=${db};User Id=${username};Password=${password};Encrypt=True;TrustServerCertificate=False;`;
                            }
                        }
                    } else if (key === 'accessKeyId' || key === 'secretAccessKey') {
                        username = formData.get('accessKeyId');
                        apiKey = formData.get('secretAccessKey');
                        additionalConfig.region = formData.get('region');
                    } else {
                        additionalConfig[key] = value;
                    }
                }
            }

            const response = await fetch('/DataSource/Connect', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': getAntiForgeryToken()
                },
                body: new URLSearchParams({
                    provider: provider,
                    name: name,
                    connectionString: connectionString || '',
                    apiEndpoint: apiEndpoint || '',
                    apiKey: apiKey || '',
                    username: username || '',
                    password: password || '',
                    additionalConfig: JSON.stringify(additionalConfig)
                })
            });

            const result = await response.json();

            if (result.success) {
                showToast(`Successfully connected to ${selectedProvider.name}!`, 'success');
                form.reset();
                cancelProviderSelection();
                loadConnectedDataSources();
                loadDataSources(); // Update status in sidebar
            } else {
                showToast('Connection failed: ' + (result.error || 'Unknown error'), 'danger');
            }
        } catch (error) {
            showToast('Failed to connect: ' + error.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-plug me-1"></i>Test & Connect';
        }
    }

    async function loadConnectedDataSources() {
        try {
            const response = await fetch('/DataSource/GetConnections');
            const result = await response.json();

            if (!result.success) return;

            const container = document.getElementById('dataSourcesList');
            if (!container) return;

            if (!result.connections || result.connections.length === 0) {
                container.innerHTML = `
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-database fs-3"></i>
                        <p class="small mb-0">No data sources connected yet</p>
                    </div>`;
                return;
            }

            const typeIcons = {
                'SQL Databases': 'database-fill',
                'NoSQL Databases': 'database',
                'Cloud Storage': 'cloud-arrow-up',
                'CRM & ERP': 'diagram-3',
                'Analytics & Marketing': 'graph-up',
                'APIs & Web Services': 'cloud-arrow-down',
                'Streaming & Events': 'arrow-repeat',
                'Files & Data Feeds': 'file-earmark-text',
                'Financial Data': 'cash',
                'Developer Tools': 'code-slash'
            };

            let html = '<div class="list-group">';
            result.connections.forEach(conn => {
                const icon = typeIcons[conn.sourceType] || 'database';
                const date = new Date(conn.connectedAt).toLocaleDateString();
                const statusColor = conn.lastSyncStatus === 'Connected' || conn.lastSyncStatus === 'Success' ? '#28a745' : 
                                  conn.lastSyncStatus === 'Failed' ? '#dc3545' : '#ffc107';

                html += `
                    <div class="list-group-item">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" 
                                 style="width:40px;height:40px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                                <i class="bi bi-${icon}" style="color:white;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-medium">${escapeHtml(conn.name)}</div>
                                <div class="small text-muted">
                                    ${conn.provider} • ${conn.sourceType}
                                    ${conn.lastSyncAt ? ' • Last sync: ' + new Date(conn.lastSyncAt).toLocaleString() : ''}
                                </div>
                                <div class="small mt-1">
                                    <span class="badge" style="background-color:${statusColor};">
                                        ${conn.lastSyncStatus || 'Unknown'}
                                    </span>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary" onclick="testConnection(${conn.id})" title="Test Connection">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-info" onclick="syncDataSource(${conn.id})" title="Sync">
                                    <i class="bi bi-cloud-download"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="confirmRemoveDataSource(${conn.id})" title="Disconnect">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
                    </div>`;
            });
            html += '</div>';

            container.innerHTML = html;
        } catch (error) {
            console.error('Failed to load connected data sources:', error);
        }
    }

    async function testConnection(connectionId) {
        const btn = event.target.closest('button');
        const originalHTML = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        try {
            const formData = new FormData();
            formData.append('connectionId', connectionId);
            formData.append('__RequestVerificationToken', getAntiForgeryToken());

            const response = await fetch('/DataSource/TestConnection', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                showToast('Connection test successful!', 'success');
            } else {
                showToast('Connection test failed: ' + (result.error || 'Unknown error'), 'danger');
            }

            loadConnectedDataSources(); // Refresh list
        } catch (error) {
            showToast('Failed to test connection: ' + error.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHTML;
        }
    }

    async function syncDataSource(connectionId) {
        const btn = event.target.closest('button');
        const originalHTML = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        try {
            const formData = new FormData();
            formData.append('connectionId', connectionId);
            formData.append('__RequestVerificationToken', getAntiForgeryToken());

            const response = await fetch('/DataSource/Sync', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                showToast(`Sync successful! Processed ${result.recordsProcessed} records.`, 'success');
            } else {
                showToast('Sync failed: ' + (result.error || 'Unknown error'), 'danger');
            }

            loadConnectedDataSources(); // Refresh list
        } catch (error) {
            showToast('Failed to sync: ' + error.message, 'danger');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHTML;
        }
    }

    function confirmRemoveDataSource(id) {
        showConfirmModal(
            'Disconnect Data Source',
            'Are you sure you want to disconnect this data source? This will not delete any data.',
            () => removeDataSource(id)
        );
    }

    async function removeDataSource(id) {
        try {
            const formData = new FormData();
            formData.append('connectionId', id);
            formData.append('__RequestVerificationToken', getAntiForgeryToken());

            const response = await fetch('/DataSource/Disconnect', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                showToast('Data source disconnected successfully!', 'success');
                loadConnectedDataSources();
                loadDataSources(); // Update sidebar status
            } else {
                showToast('Failed to disconnect: ' + (result.error || 'Unknown error'), 'danger');
            }
        } catch (error) {
            showToast('Failed to disconnect: ' + error.message, 'danger');
        }
    }

    async function loadDataSources() {
        try {
            const response = await fetch('/DataSource/GetConnections');
            const result = await response.json();

            if (!result.success) return;

            const dataSources = result.connections || [];
            const container = document.querySelector('[data-datasource-status]');

            if (container) {
                if (dataSources.length > 0) {
                    const activeCount = dataSources.filter(ds => ds.lastSyncStatus === 'Connected' || ds.lastSyncStatus === 'Success').length;
                    container.innerHTML = `
                        <div class="d-flex align-items-center gap-2 mb-1" style="font-size:0.8rem;">
                            <i class="bi bi-database-check" style="color:#28a745;"></i>
                            <span>${activeCount} of ${dataSources.length} active</span>
                        </div>`;
                } else {
                    container.innerHTML = `
                        <div class="d-flex align-items-center gap-2 mb-1" style="font-size:0.8rem;">
                            <i class="bi bi-database" style="color:#667eea;"></i>
                            <span>No data sources connected</span>
                        </div>`;
                }
            }
        } catch (error) {
            console.error('Failed to load data sources status:', error);
        }
    }
        } catch (error) {
            console.error('Failed to load data sources:', error);
        }
    }

    function removeDataSource(id) {
        try {
            const dataSources = JSON.parse(localStorage.getItem('chatportal_datasources') || '[]');
            const filtered = dataSources.filter(ds => ds.id !== id);
            localStorage.setItem('chatportal_datasources', JSON.stringify(filtered));
            showToast('Data source removed successfully!', 'success');
            loadDataSources();
        } catch (error) {
            showToast('Failed to remove data source: ' + error.message, 'danger');
        }
    }

    // Load data sources on page load
    document.addEventListener('DOMContentLoaded', function() {
        loadDataSources();
    });

    // ── Edit Workspace (Placeholder) ───────────────────────────────────────
    function editWorkspace(id) {
        showToast('Workspace editing feature coming soon!', 'info');
        // TODO: Open modal to edit workspace name, description, context
    }
</script>
