<!-- ── Data Source Connection Modal ── -->
<div class="modal fade" id="dataSourceModal" tabindex="-1" aria-labelledby="dataSourceLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-2" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                <h5 class="modal-title fw-bold text-white" id="dataSourceLabel">
                    <i class="bi bi-database-add me-2"></i>Connect to Data Sources
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" style="max-height:70vh;overflow-y:auto;">

                <!-- ── My Connected Data Sources ── -->
                <div id="dsListView">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h6 class="fw-semibold mb-0">My Data Sources</h6>
                        <button class="btn btn-sm btn-primary" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);border:none;" onclick="startDsWizard()">
                            <i class="bi bi-plus-circle me-1"></i>Connect New Data Source
                        </button>
                    </div>
                    <div id="userDataSourcesList">
                        <div class="text-center text-muted py-4">
                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                            Loading data sources...
                        </div>
                    </div>
                </div>

                <!-- ── Wizard ── -->
                <div id="dsWizardView" style="display:none;">
                    <!-- Step indicators -->
                    <div class="d-flex align-items-center mb-4" id="dsWizardSteps">
                        <div class="wizard-step active" data-step="1">
                            <span class="step-circle">1</span>
                            <span class="step-label d-none d-sm-inline ms-1">Provider</span>
                        </div>
                        <div class="wizard-step-line flex-grow-1"></div>
                        <div class="wizard-step" data-step="2">
                            <span class="step-circle">2</span>
                            <span class="step-label d-none d-sm-inline ms-1">Details</span>
                        </div>
                        <div class="wizard-step-line flex-grow-1"></div>
                        <div class="wizard-step" data-step="3">
                            <span class="step-circle">3</span>
                            <span class="step-label d-none d-sm-inline ms-1">Tables</span>
                        </div>
                        <div class="wizard-step-line flex-grow-1"></div>
                        <div class="wizard-step" data-step="4">
                            <span class="step-circle">4</span>
                            <span class="step-label d-none d-sm-inline ms-1">Confirm</span>
                        </div>
                    </div>

                    <!-- Step 1: Select Provider Type -->
                    <div id="dsStep1">
                        <h6 class="fw-semibold mb-3">Step 1 — Select Provider Type</h6>
                        <div class="row g-3" id="dsProviderCards">
                            @foreach (var prov in new[] {
                                new { Id="SqlServer",     Name="SQL Server",     Icon="server",           Desc="Microsoft SQL Server" },
                                new { Id="PostgreSQL",    Name="PostgreSQL",     Icon="database",         Desc="Open-source relational DB" },
                                new { Id="MySQL",         Name="MySQL",          Icon="database-fill",    Desc="Popular relational DB" },
                                new { Id="MongoDB",       Name="MongoDB",        Icon="diagram-3",        Desc="NoSQL document store" },
                                new { Id="Oracle",        Name="Oracle",         Icon="hdd-stack",        Desc="Enterprise relational DB" },
                                new { Id="Elasticsearch", Name="Elasticsearch",  Icon="search",           Desc="Search &amp; analytics engine" },
                                new { Id="Redis",         Name="Redis",          Icon="lightning-charge", Desc="In-memory data store" },
                                new { Id="Excel",         Name="Excel / CSV",    Icon="file-earmark-spreadsheet", Desc="Upload .xlsx, .xls or .csv" }
                            })
                            {
                                <div class="col-sm-6 col-md-4 col-lg-3">
                                    <div class="card h-100 ds-provider-card" style="cursor:pointer;border:2px solid #e2e8f0;transition:all 0.2s;"
                                         onclick="dsSelectProvider('@prov.Id','@prov.Name')">
                                        <div class="card-body text-center py-3 px-2">
                                            <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center mb-2"
                                                 style="width:44px;height:44px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                                                <i class="bi bi-@prov.Icon" style="color:white;font-size:1.1rem;"></i>
                                            </div>
                                            <div class="fw-semibold small">@prov.Name</div>
                                            <small class="text-muted" style="font-size:0.7rem;">@Html.Raw(prov.Desc)</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-sm btn-outline-secondary" onclick="cancelDsWizard()">
                                <i class="bi bi-arrow-left me-1"></i>Back to list
                            </button>
                        </div>
                    </div>

                    <!-- Step 2: Connection Details -->
                    <div id="dsStep2" style="display:none;">
                        <h6 class="fw-semibold mb-3">Step 2 — Enter Connection Details</h6>
                        <div id="dsStep2Form"></div>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-sm btn-outline-secondary" onclick="dsGoToStep(1)">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </button>
                            <button class="btn btn-sm btn-outline-info" id="dsTestBtn" onclick="dsTestConnection()">
                                <i class="bi bi-plug me-1"></i>Test Connection
                            </button>
                            <button class="btn btn-sm btn-primary ms-auto" id="dsNextStep2Btn" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);border:none;" onclick="dsProceedToTables()" disabled>
                                Next <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                        <div id="dsTestResult" class="mt-2"></div>
                    </div>

                    <!-- Step 3: Select Tables -->
                    <div id="dsStep3" style="display:none;">
                        <h6 class="fw-semibold mb-3">Step 3 — Select Tables / Collections</h6>
                        <p class="text-muted small">Select which tables or collections the AI can query.</p>
                        <div id="dsTablesList" class="row g-2"></div>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-sm btn-outline-secondary" onclick="dsGoToStep(2)">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </button>
                            <button class="btn btn-sm btn-primary ms-auto" style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);border:none;" onclick="dsProceedToConfirm()">
                                Next <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Step 4: Confirmation -->
                    <div id="dsStep4" style="display:none;">
                        <h6 class="fw-semibold mb-3">Step 4 — Confirm & Save</h6>
                        <div id="dsConfirmSummary" class="alert alert-info small"></div>
                        <div class="d-flex gap-2 mt-3">
                            <button class="btn btn-sm btn-outline-secondary" onclick="dsGoToStep(3)">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </button>
                            <button class="btn btn-sm btn-success ms-auto" id="dsFinishBtn" onclick="dsFinish()">
                                <i class="bi bi-check-circle me-1"></i>Finish
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
.wizard-step { display:flex;align-items:center;flex-direction:column; }
.step-circle { width:28px;height:28px;border-radius:50%;background:#e2e8f0;color:#666;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:600; }
.wizard-step.active .step-circle { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#fff; }
.wizard-step.done .step-circle { background:#28a745;color:#fff; }
.wizard-step-line { height:2px;background:#e2e8f0;margin:0 4px;margin-top:-14px; }
.ds-provider-card:hover { border-color:#667eea !important;transform:scale(1.03); }
.ds-provider-card.selected { border-color:#667eea !important;background:#f0f0ff; }
</style>

<!-- ── Toast Container for Notifications ── -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

@section Scripts {
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<!-- Markdown parsing -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<!-- XSS sanitisation -->
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.6/dist/purify.min.js"></script>
<!-- Syntax highlighting -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<!-- PDF export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<!-- SignalR -->
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
<!-- Chat history (localStorage) must load before chat.js -->
<script src="~/js/chatHistory.js" asp-append-version="true"></script>
<script src="~/js/chat.js" asp-append-version="true"></script>
<script>
    // ── Utility Functions ──────────────────────────────────────────────────
    // Escape HTML to prevent XSS
    function escapeHtml(unsafe) {
        if (!unsafe) return '';
        return unsafe
            .toString()
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Get anti-forgery token for AJAX requests
    function getAntiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    }

    // Configure marked.js
    if (typeof marked !== 'undefined') {
        marked.setOptions({ breaks: true, gfm: true });
    }

    // SignalR
    const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/chat").build();
    connection.start().catch(err => console.warn("SignalR:", err));
    connection.on("ReceiveMessage", (role, content) => appendMessage(role, content));

    // Team switcher
    document.querySelectorAll('.team-option').forEach(item => {
        item.addEventListener('click', function (e) {
            e.preventDefault();
            document.querySelectorAll('.team-option').forEach(i => i.classList.remove('active-team'));
            this.classList.add('active-team');
            document.getElementById('activeTeamName').textContent = this.dataset.team;
        });
    });

    // Organization switcher
    document.querySelectorAll('.org-option').forEach(item => {
        item.addEventListener('click', function (e) {
            e.preventDefault();
            document.querySelectorAll('.org-option').forEach(i => i.classList.remove('active-org'));
            this.classList.add('active-org');
            document.getElementById('activeOrgName').textContent = this.dataset.org;

            // Set active organization and reload workspaces
            const orgId = this.getAttribute('data-org-id');
            if (orgId) {
                setActiveOrganization(orgId);
            }
        });
    });

    // Workspace switcher
    document.querySelectorAll('.workspace-option').forEach(item => {
        item.addEventListener('click', function (e) {
            e.preventDefault();
            document.querySelectorAll('.workspace-option').forEach(i => i.classList.remove('active-workspace'));
            this.classList.add('active-workspace');
            document.getElementById('activeWorkspaceName').textContent = this.dataset.workspace;
        });
    });

    // Load organizations on page load
    document.addEventListener('DOMContentLoaded', function() {
        loadOrganizations();
        loadWorkspaces();
        loadAvailableAgents(); // Load agents for selection
    });

    // ── AI Agent Selection & Management ──────────────────────────────────
    let selectedAgent = null;

    async function loadAvailableAgents() {
        try {
            const response = await fetch('/Workspace/GetUserWorkspaces');
            const result = await response.json();

            if (result.success && result.workspaces) {
                // Get all agents from all workspaces
                const agentPromises = result.workspaces.map(ws => 
                    fetch(`/Agent/GetWorkspaceAgents?workspaceId=${ws.id}`)
                        .then(r => r.json())
                        .then(data => data.success ? data.agents.map(a => ({...a, workspaceName: ws.name})) : [])
                );

                const agentArrays = await Promise.all(agentPromises);
                const allAgents = agentArrays.flat();

                displayAgentSelector(allAgents);
            }
        } catch (error) {
            console.error('Failed to load agents for selection:', error);
        }
    }

    function displayAgentSelector(agents) {
        const select = document.getElementById('agentSelect');
        select.innerHTML = '<option value="">-- Select AI Agent --</option>';

        agents.forEach(agent => {
            if (agent.isActive) {
                const option = document.createElement('option');
                option.value = agent.id;
                option.textContent = `${agent.name} (${agent.workspaceName}) - ${agent.agentType}`;
                option.dataset.agent = JSON.stringify(agent);
                select.appendChild(option);
            }
        });
    }

    function selectAgent() {
        const select = document.getElementById('agentSelect');
        const selectedOption = select.options[select.selectedIndex];

        if (!selectedOption.value) {
            selectedAgent = null;
            document.getElementById('selectedAgentName').textContent = 'No Agent Selected';
            document.getElementById('agentStatus').innerHTML = '<i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Select an agent to start';
            document.getElementById('agentStatus').style.color = '#e74c3c';
            document.getElementById('shareAgentBtn').disabled = true;
            document.getElementById('exportAgentBtn').disabled = true;
            document.getElementById('messageInput').disabled = true;
            document.getElementById('sendBtn').disabled = true;
            return;
        }

        selectedAgent = JSON.parse(selectedOption.dataset.agent);
        document.getElementById('selectedAgentName').textContent = selectedAgent.name;
        document.getElementById('agentStatus').innerHTML = `<i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>${selectedAgent.agentType} • ${selectedAgent.modelName}`;
        document.getElementById('agentStatus').style.color = '#2ecc71';
        document.getElementById('shareAgentBtn').disabled = false;
        document.getElementById('exportAgentBtn').disabled = false;
        document.getElementById('messageInput').disabled = false;
        document.getElementById('sendBtn').disabled = false;

        // Update model select to match agent's model
        const modelSelect = document.getElementById('modelSelect');
        for (let i = 0; i < modelSelect.options.length; i++) {
            if (modelSelect.options[i].value === selectedAgent.modelName) {
                modelSelect.selectedIndex = i;
                break;
            }
        }

        // Clear chat for new agent
        clearChat();
    }

    function shareAgent() {
        if (!selectedAgent) {
            showToast('Please select an agent first', 'warning');
            return;
        }

        const shareUrl = `${window.location.origin}/Chat/Agent/${selectedAgent.id}`;

        if (navigator.share) {
            navigator.share({
                title: `Chat with ${selectedAgent.name}`,
                text: `Try chatting with my AI agent: ${selectedAgent.name} - ${selectedAgent.description || 'Intelligent AI assistant'}`,
                url: shareUrl
            }).catch(() => {
                // Fallback to copy
                copyToClipboard(shareUrl);
                showToast('Share link copied to clipboard!', 'success');
            });
        } else {
            copyToClipboard(shareUrl);
            showToast('Share link copied to clipboard!', 'success');
        }
    }

    function generateAgentEmbed() {
        if (!selectedAgent) {
            showToast('Please select an agent first', 'warning');
            return;
        }

        const agentId = selectedAgent.id;
        const shareUrl = `${window.location.origin}/Chat/Agent/${agentId}`;
        const embedCode = `<iframe src="${shareUrl}" width="400" height="600" frameborder="0" allow="microphone" style="border-radius:8px;box-shadow:0 4px 6px rgba(0,0,0,0.1);"></iframe>`;

        document.getElementById('embedAgentDisplayName').textContent = selectedAgent.name;
        document.getElementById('embedAgentDisplayType').textContent = `${selectedAgent.agentType} • ${selectedAgent.modelName}`;
        document.getElementById('agentShareLink').value = shareUrl;
        document.getElementById('agentEmbedCode').value = embedCode;
    }

    function copyShareLink() {
        const input = document.getElementById('agentShareLink');
        copyToClipboard(input.value);
        showToast('Share link copied to clipboard!', 'success');
    }

    function copyEmbedCode() {
        const input = document.getElementById('agentEmbedCode');
        copyToClipboard(input.value);
        showToast('Embed code copied to clipboard!', 'success');
    }

    function previewAgentEmbed() {
        const shareUrl = document.getElementById('agentShareLink').value;
        if (!shareUrl) {
            showToast('Please generate the agent embed first', 'warning');
            return;
        }
        // Open in new window with specific dimensions
        const previewWindow = window.open(shareUrl, 'AgentPreview', 'width=450,height=650,resizable=yes,scrollbars=yes');
        if (!previewWindow) {
            showToast('Popup blocked! Please allow popups for this site.', 'warning');
        }
    }

    function copyToClipboard(text) {
        if (navigator.clipboard) {
            navigator.clipboard.writeText(text);
        } else {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
        }
    }

    // Update agent modal when opened
    document.getElementById('embedAgentModal')?.addEventListener('show.bs.modal', function() {
        generateAgentEmbed();
    });

    // Organization Management Functions
    async function createOrganization(event) {
        event.preventDefault();
        const form = event.target;
        const formData = new FormData(form);

        try {
            const response = await fetch('/Organization/Create', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': form.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                showToast('Organization created successfully!', 'success');
                form.reset();
                loadOrganizations();
            } else {
                showToast('Error: ' + result.error, 'danger');
            }
        } catch (error) {
            showToast('Failed to create organization: ' + error.message, 'danger');
        }
    }

    async function loadOrganizations() {
        try {
            const response = await fetch('/Organization/GetUserOrganizations');
            const result = await response.json();

            if (result.success && result.organizations) {
                displayOrganizations(result.organizations);
            }
        } catch (error) {
            console.error('Failed to load organizations:', error);
        }
    }

    function displayOrganizations(organizations) {
        const dropdown = document.getElementById('organizationDropdown');
        const listContainer = document.getElementById('organizationsList');
        const createSection = document.getElementById('createOrgSection');
        const divider = document.getElementById('orgDivider');

        if (organizations.length === 0) {
            // Show create form if no organization exists
            if (createSection) createSection.style.display = 'block';
            if (divider) divider.style.display = 'block';
            listContainer.innerHTML = '<div class="text-center text-muted py-3"><p class="small">No organization yet. Create one to get started!</p></div>';
            return;
        }

        // Hide create form if organization already exists
        if (createSection) createSection.style.display = 'none';
        if (divider) divider.style.display = 'none';

        // Since user can only have one organization, display it
        const org = organizations[0];

        // Update dropdown
        let dropdownHTML = `
            <li>
                <a class="dropdown-item org-option active-org d-flex align-items-center gap-2" 
                   href="#" data-org="${org.name}" data-org-id="${org.id}">
                    <i class="bi bi-building" style="color:#667eea;font-size:0.8rem;"></i>
                    <div>
                        <div style="font-size:0.85rem;color:#2d3748;">${org.name}</div>
                        <div class="text-muted" style="font-size:0.7rem;">${org.userRole} • ${org.workspaceCount} workspaces</div>
                    </div>
                </a>
            </li>
            <li><hr class="dropdown-divider my-1"></li>
            <li>
                <a class="dropdown-item d-flex align-items-center gap-2" href="#" data-bs-toggle="modal" data-bs-target="#organizationManagementModal" style="font-size:0.82rem;color:#667eea;">
                    <i class="bi bi-gear me-1"></i>Manage Organization
                </a>
            </li>`;
        dropdown.innerHTML = dropdownHTML;

        // Update list
        let listHTML = `
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h6 class="fw-bold mb-1">${org.name}</h6>
                        <p class="text-muted small mb-2">${org.description || 'No description'}</p>
                        <div class="d-flex gap-3 small">
                            <span><i class="bi bi-people me-1"></i>${org.memberCount} members</span>
                            <span><i class="bi bi-grid me-1"></i>${org.workspaceCount} workspaces</span>
                            ${org.industry ? `<span><i class="bi bi-briefcase me-1"></i>${org.industry}</span>` : ''}
                        </div>
                    </div>
                    ${org.isOwner ? `
                        <button class="btn btn-sm btn-outline-secondary" title="Manage Members" onclick="openOrgMemberModal(${org.id})">
                            <i class="bi bi-person-plus me-1"></i>Add Members
                        </button>
                    ` : ''}
                </div>
                <div class="alert alert-info small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    You are the ${org.userRole} of this organization. ${org.isOwner ? 'You can add members, create workspaces, and manage teams.' : 'Contact the owner to create workspaces or add members.'}
                </div>
            </div>`;
        listContainer.innerHTML = listHTML;

        // Set as active organization
        document.getElementById('activeOrgName').textContent = org.name;

        // Automatically set as active in session
        setActiveOrganization(org.id);

        // Reattach event listeners
        document.querySelectorAll('.org-option').forEach(item => {
            item.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelectorAll('.org-option').forEach(i => i.classList.remove('active-org'));
                this.classList.add('active-org');
                document.getElementById('activeOrgName').textContent = this.getAttribute('data-org');
                const orgId = this.getAttribute('data-org-id');
                if (orgId) setActiveOrganization(orgId);
            });
        });
    }

    async function setActiveOrganization(orgId) {
        try {
            const response = await fetch('/Organization/SetActive', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: `id=${orgId}`
            });

            const result = await response.json();
            if (result.success) {
                loadWorkspaces();
            }
        } catch (error) {
            console.error('Failed to set active organization:', error);
        }
    }

    // Organization Member Management
    function openOrgMemberModal(orgId) {
        document.getElementById('orgMemberId').value = orgId;
        const modal = new bootstrap.Modal(document.getElementById('orgMemberModal'));
        modal.show();
    }

    async function addOrgMember(event) {
        event.preventDefault();
        const form = event.target;
        const formData = new FormData(form);

        try {
            const response = await fetch('/Invitation/SendOrganizationInvite', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': form.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                if (result.userExists) {
                    showToast('User added to organization successfully!', 'success');
                } else {
                    showToast(`Invitation sent to ${formData.get('email')}!`, 'success');
                    // Optionally copy invite link to clipboard
                    copyToClipboard(result.inviteLink);
                    showToast('Invitation link copied to clipboard', 'info');
                }
                form.reset();
                bootstrap.Modal.getInstance(document.getElementById('orgMemberModal')).hide();
                loadOrganizations(); // Refresh organization to show updated member count
            } else {
                showToast('Error: ' + result.error, 'danger');
            }
        } catch (error) {
            showToast('Failed to add organization member: ' + error.message, 'danger');
        }
    }

    // Workspace Management Functions
    async function createWorkspace(event) {
        event.preventDefault();
        const form = event.target;
        const formData = new FormData(form);

        try {
            const response = await fetch('/Workspace/Create', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': form.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                showToast('Workspace created successfully!', 'success');
                form.reset();
                loadWorkspaces();
                bootstrap.Modal.getInstance(document.getElementById('workspaceManagementModal')).hide();
            } else {
                showToast('Error: ' + result.error, 'danger');
            }
        } catch (error) {
            showToast('Failed to create workspace: ' + error.message, 'danger');
        }
    }

    async function loadWorkspaces() {
        try {
            const response = await fetch('/Workspace/GetUserWorkspaces');
            const result = await response.json();

            if (result.success && result.workspaces) {
                displayWorkspaces(result.workspaces);
            }
        } catch (error) {
            console.error('Failed to load workspaces:', error);
        }
    }

    function displayWorkspaces(workspaces) {
        const dropdown = document.getElementById('workspaceDropdown');
        const listContainer = document.getElementById('workspacesList');

        if (workspaces.length === 0) {
            listContainer.innerHTML = '<div class="text-center text-muted py-3"><p class="small">No workspaces yet. Create one to get started!</p></div>';
            return;
        }

        // Update dropdown
        let dropdownHTML = '';
        workspaces.forEach((ws, index) => {
            dropdownHTML += `
                <li>
                    <a class="dropdown-item workspace-option ${index === 0 ? 'active-workspace' : ''} d-flex align-items-center gap-2" 
                       href="#" data-workspace="${ws.name}">
                        <i class="bi bi-grid-fill" style="color:#764ba2;font-size:0.8rem;"></i>
                        <div>
                            <div style="font-size:0.85rem;color:#2d3748;">${ws.name}</div>
                            <div class="text-muted" style="font-size:0.7rem;">${ws.chatAgentContext} • ${ws.agentCount} agents</div>
                        </div>
                    </a>
                </li>`;
        });
        dropdownHTML += `
            <li><hr class="dropdown-divider my-1"></li>
            <li>
                <a class="dropdown-item d-flex align-items-center gap-2" href="#" data-bs-toggle="modal" data-bs-target="#agentManagementModal" style="font-size:0.82rem;color:#667eea;">
                    <i class="bi bi-robot me-1"></i>Manage AI Agents
                </a>
            </li>
            <li>
                <a class="dropdown-item d-flex align-items-center gap-2" href="#" data-bs-toggle="modal" data-bs-target="#workspaceManagementModal" style="font-size:0.82rem;color:#764ba2;">
                    <i class="bi bi-plus-circle me-1"></i>Create Workspace
                </a>
            </li>`;
        dropdown.innerHTML = dropdownHTML;

        // Update list
        let listHTML = '';
        workspaces.forEach(ws => {
            listHTML += `
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-medium">${ws.name}</div>
                        <small class="text-muted">${ws.chatAgentContext} • ${ws.agentCount} agents • ${ws.isActive ? 'Active' : 'Inactive'}</small>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" title="Manage AI Agents" 
                                onclick="openAgentModal(${ws.id})" style="border-color:#667eea;color:#667eea;">
                            <i class="bi bi-robot"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" title="Edit" onclick="editWorkspace(${ws.id})">
                            <i class="bi bi-pencil"></i>
                        </button>
                        ${ws.isOwner ? `
                            <button class="btn btn-sm btn-outline-danger" title="Delete" onclick="deleteWorkspace(${ws.id})">
                                <i class="bi bi-trash3"></i>
                            </button>
                        ` : ''}
                    </div>
                </div>`;
        });
        listContainer.innerHTML = listHTML;

        // Set first workspace as active
        if (workspaces.length > 0) {
            document.getElementById('activeWorkspaceName').textContent = workspaces[0].name;
        }

        // Reattach event listeners
        document.querySelectorAll('.workspace-option').forEach(item => {
            item.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelectorAll('.workspace-option').forEach(i => i.classList.remove('active-workspace'));
                this.classList.add('active-workspace');
                document.getElementById('activeWorkspaceName').textContent = this.getAttribute('data-workspace');
            });
        });
    }

    function deleteWorkspace(id) {
        showConfirmModal(
            'Delete Workspace',
            'Are you sure you want to delete this workspace? All agents will be removed.',
            async () => {
                try {
                    const response = await fetch('/Workspace/Delete', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                        },
                        body: `id=${id}`
                    });

                    const result = await response.json();
                    if (result.success) {
                        showToast('Workspace deleted successfully!', 'success');
                        loadWorkspaces();
                    } else {
                        showToast('Error: ' + result.error, 'danger');
                    }
                } catch (error) {
                    showToast('Failed to delete workspace: ' + error.message, 'danger');
                }
            }
        );
    }

    // ── Agent Management Functions ───────────────────────────────────────
    let currentAgentWorkspaceId = null;

    // Helper function to open agent modal with pre-selected workspace
    function openAgentModal(workspaceId = null) {
        const modal = new bootstrap.Modal(document.getElementById('agentManagementModal'));
        modal.show();

        if (workspaceId) {
            // Wait for modal to be shown, then set workspace and load agents
            document.getElementById('agentManagementModal').addEventListener('shown.bs.modal', function() {
                const select = document.getElementById('agentWorkspaceSelect');
                select.value = workspaceId;
                loadAgents();
            }, { once: true });
        }
    }

    // Populate workspace dropdown when agent modal opens
    document.getElementById('agentManagementModal')?.addEventListener('show.bs.modal', function() {
        populateAgentWorkspaceDropdown();
    });

    async function populateAgentWorkspaceDropdown() {
        try {
            const response = await fetch('/Workspace/GetUserWorkspaces');
            const result = await response.json();

            const select = document.getElementById('agentWorkspaceSelect');
            select.innerHTML = '<option value="">-- Select a workspace --</option>';

            if (result.success && result.workspaces) {
                result.workspaces.forEach(ws => {
                    const option = document.createElement('option');
                    option.value = ws.id;
                    option.textContent = `${ws.name} (${ws.agentCount} agents)`;
                    select.appendChild(option);
                });
            }
        } catch (error) {
            console.error('Failed to load workspaces for agent management:', error);
        }
    }

    async function loadAgents() {
        const workspaceId = document.getElementById('agentWorkspaceSelect').value;
        const content = document.getElementById('agentWorkspaceContent');

        if (!workspaceId) {
            content.style.display = 'none';
            return;
        }

        currentAgentWorkspaceId = parseInt(workspaceId);
        content.style.display = 'block';

        try {
            const response = await fetch(`/Agent/GetWorkspaceAgents?workspaceId=${workspaceId}`);
            const result = await response.json();

            if (result.success && result.agents) {
                displayAgents(result.agents);
            }
        } catch (error) {
            console.error('Failed to load agents:', error);
        }
    }

    function displayAgents(agents) {
        const container = document.getElementById('agentsList');

        if (agents.length === 0) {
            container.innerHTML = `
                <div class="col-12 text-center text-muted py-3">
                    <i class="bi bi-robot fs-2"></i>
                    <p class="small mb-0">No agents yet. Create one to get started!</p>
                </div>`;
            return;
        }

        let html = '';
        agents.forEach(agent => {
            const agentTypeIcons = {
                'general': 'robot',
                'code': 'code-slash',
                'writing': 'pen',
                'data': 'graph-up',
                'research': 'search',
                'customer-service': 'headset'
            };
            const icon = agentTypeIcons[agent.agentType] || 'robot';
            const statusBadge = agent.isActive 
                ? '<span class="badge bg-success">Active</span>' 
                : '<span class="badge bg-secondary">Inactive</span>';

            html += `
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center" 
                                         style="width:40px;height:40px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                                        <i class="bi bi-${icon}" style="color:white;"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold">${agent.name}</h6>
                                        <small class="text-muted">${agent.agentType}</small>
                                    </div>
                                </div>
                                ${statusBadge}
                            </div>
                            <p class="small text-muted mb-2">${agent.description || 'No description'}</p>
                            <div class="d-flex gap-2 small text-muted mb-3">
                                <span><i class="bi bi-cpu me-1"></i>${agent.modelName}</span>
                                <span><i class="bi bi-thermometer-half me-1"></i>T:${agent.temperature}</span>
                                <span><i class="bi bi-chat-dots me-1"></i>${agent.chatSessionCount} chats</span>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary flex-grow-1" 
                                        onclick="toggleAgentActive(${agent.id})" title="${agent.isActive ? 'Deactivate' : 'Activate'}">
                                    <i class="bi bi-power"></i>
                                </button>
                                ${agent.isCreator ? `
                                    <button class="btn btn-sm btn-outline-danger" 
                                            onclick="deleteAgent(${agent.id})" title="Delete">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                ` : ''}
                            </div>
                        </div>
                    </div>
                </div>`;
        });

        container.innerHTML = html;
    }

    async function createAgent(event) {
        event.preventDefault();
        const form = event.target;
        const formData = new FormData(form);
        formData.append('workspaceId', currentAgentWorkspaceId);

        try {
            const response = await fetch('/Agent/Create', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': form.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                showToast('AI Agent created successfully!', 'success');
                form.reset();
                loadAgents();
                loadWorkspaces(); // Refresh workspace list to update agent count
                loadAvailableAgents(); // Refresh agent selector
            } else {
                showToast('Error: ' + result.error, 'danger');
            }
        } catch (error) {
            showToast('Failed to create agent: ' + error.message, 'danger');
        }
    }

    async function toggleAgentActive(agentId) {
        try {
            const response = await fetch('/Agent/ToggleActive', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                },
                body: `id=${agentId}`
            });

            const result = await response.json();
            if (result.success) {
                loadAgents();
                loadAvailableAgents(); // Refresh agent selector
                showToast(result.isActive ? 'Agent activated' : 'Agent deactivated', 'success');
            } else {
                showToast('Error: ' + result.error, 'danger');
            }
        } catch (error) {
            showToast('Failed to toggle agent status: ' + error.message, 'danger');
        }
    }

    function deleteAgent(agentId) {
        showConfirmModal(
            'Delete AI Agent',
            'Are you sure you want to delete this AI agent? All associated chat sessions will remain but won\'t be linked to this agent.',
            async () => {
                try {
                    const response = await fetch('/Agent/Delete', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value
                        },
                        body: `id=${agentId}`
                    });

                    const result = await response.json();
                    if (result.success) {
                        showToast('Agent deleted successfully!', 'success');
                        loadAgents();
                        loadWorkspaces();
                        loadAvailableAgents(); // Refresh agent selector
                    } else {
                        showToast('Error: ' + result.error, 'danger');
                    }
                } catch (error) {
                    showToast('Failed to delete agent: ' + error.message, 'danger');
                }
            }
        );
    }

