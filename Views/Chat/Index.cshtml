    // ── Agent embed helpers ───────────────────────────────────────────────
    async function generateEmbedToken() {
        const btn = document.getElementById('generateEmbedTokenBtn');
        const status = document.getElementById('embedTokenStatus');
        btn.disabled = true;
        status.textContent = 'Generating\u2026';
        try {
            const resp = await fetch('/Account/GenerateEmbedToken', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                }
            });
            const data = await resp.json();
            if (data.success && data.token) {
                const origin = window.location.origin;
                const iframeUrl = `${origin}/Embed/Chat?token=${encodeURIComponent(data.token)}`;
                document.getElementById('embedTokenDisplay').value = data.token;
                document.getElementById('embedIframeCode').value =
                    `<iframe src="${iframeUrl}" width="400" height="600" frameborder="0" allow="microphone"></iframe>`;
                document.getElementById('embedCodeSection').classList.remove('d-none');
                status.textContent = '';
            } else {
                status.textContent = data.error || 'Failed to generate token.';
            }
        } catch {
            status.textContent = 'Request failed. Please try again.';
        } finally {
            btn.disabled = false;
        }
    }

    function copyEmbedToken() {
        const el = document.getElementById('embedTokenDisplay');
        navigator.clipboard?.writeText(el.value).catch(() => { el.select(); document.execCommand('copy'); });
    }

    function copyIframeCode() {
        const el = document.getElementById('embedIframeCode');
        navigator.clipboard?.writeText(el.value).catch(() => { el.select(); document.execCommand('copy'); });
    }

    // ── Toast Notification System ─────────────────────────────────────────
    function showToast(message, type = 'info') {
        const toastContainer = document.getElementById('toastContainer');
        const toastId = 'toast_' + Date.now();

        const bgColors = {
            success: 'bg-success',
            danger: 'bg-danger',
            warning: 'bg-warning',
            info: 'bg-info'
        };

        const icons = {
            success: 'check-circle-fill',
            danger: 'exclamation-circle-fill',
            warning: 'exclamation-triangle-fill',
            info: 'info-circle-fill'
        };

        const toastHTML = `
            <div class="toast align-items-center text-white ${bgColors[type]} border-0" role="alert" id="${toastId}">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bi bi-${icons[type]}"></i>
                        ${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        `;

        toastContainer.insertAdjacentHTML('beforeend', toastHTML);
        const toastElement = document.getElementById(toastId);
        const toast = new bootstrap.Toast(toastElement, { autohide: true, delay: 3000 });
        toast.show();

        toastElement.addEventListener('hidden.bs.toast', function() {
            toastElement.remove();
        });
    }

    // ── Confirmation Modal System ─────────────────────────────────────────
    let confirmedActionCallback = null;

    function showConfirmModal(title, message, onConfirm) {
        document.getElementById('confirmModalLabel').innerHTML = `<i class="bi bi-exclamation-triangle me-2"></i>${title}`;
        document.getElementById('confirmModalMessage').textContent = message;
        confirmedActionCallback = onConfirm;
        const modal = new bootstrap.Modal(document.getElementById('confirmModal'));
        modal.show();
    }

    async function executeConfirmedAction() {
        if (confirmedActionCallback) {
            bootstrap.Modal.getInstance(document.getElementById('confirmModal')).hide();
            await confirmedActionCallback();
            confirmedActionCallback = null;
        }
    }

