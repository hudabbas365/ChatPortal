@{
    ViewData["Title"] = "Pricing";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5" style="padding-top:100px!important;">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-6">Simple, transparent pricing</h1>
        <p class="text-muted lead">Choose the plan that fits your needs</p>
        <div class="btn-group mt-3" role="group">
            <input type="radio" class="btn-check" name="billing" id="monthly" checked />
            <label class="btn btn-outline-primary rounded-start-pill" for="monthly">Monthly</label>
            <input type="radio" class="btn-check" name="billing" id="annual" />
            <label class="btn btn-outline-primary rounded-end-pill" for="annual">Annual <span class="badge bg-success ms-1">-17%</span></label>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Free Plan -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h5 class="fw-bold">Free</h5>
                        <p class="text-muted small">Get started for free</p>
                        <div class="d-flex align-items-end gap-1">
                            <span class="display-6 fw-bold">$0</span>
                            <span class="text-muted mb-2">/month</span>
                        </div>
                    </div>
                    <ul class="list-unstyled mb-4">
                        @foreach (var feature in new[] { "100 credits/month", "1 AI model", "Basic support", "Chat history (7 days)" })
                        {
                            <li class="mb-2 small"><i class="bi bi-check text-success me-2"></i>@feature</li>
                        }
                    </ul>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary w-100">Get Started Free</a>
                </div>
            </div>
        </div>

        <!-- Pro Plan -->
        <div class="col-md-4">
            <div class="card border-0 shadow-lg rounded-4 h-100 position-relative" style="border: 2px solid #0d6efd !important;">
                <div class="position-absolute top-0 start-50 translate-middle">
                    <span class="badge bg-primary px-3 py-2 rounded-pill">Most Popular</span>
                </div>
                <div class="card-body p-4" style="background:linear-gradient(180deg,rgba(13,110,253,0.05) 0%,transparent 100%);">
                    <div class="mb-4 mt-2">
                        <h5 class="fw-bold">Pro</h5>
                        <p class="text-muted small">For professionals</p>
                        <div class="d-flex align-items-end gap-1">
                            <span class="display-6 fw-bold">$19.99</span>
                            <span class="text-muted mb-2">/month</span>
                        </div>
                    </div>
                    <ul class="list-unstyled mb-4">
                        @foreach (var feature in new[] { "1,000 credits/month", "All AI models", "Priority support", "API access", "Unlimited history", "Advanced analytics" })
                        {
                            <li class="mb-2 small"><i class="bi bi-check text-success me-2"></i>@feature</li>
                        }
                    </ul>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary w-100">Start Pro Trial</a>
                </div>
            </div>
        </div>

        <!-- Enterprise Plan -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h5 class="fw-bold">Enterprise</h5>
                        <p class="text-muted small">For teams and businesses</p>
                        <div class="d-flex align-items-end gap-1">
                            <span class="display-6 fw-bold">$99.99</span>
                            <span class="text-muted mb-2">/month</span>
                        </div>
                    </div>
                    <ul class="list-unstyled mb-4">
                        @foreach (var feature in new[] { "Unlimited credits", "All AI models", "24/7 support", "API access", "Custom integrations", "Team management", "SLA guarantee" })
                        {
                            <li class="mb-2 small"><i class="bi bi-check text-success me-2"></i>@feature</li>
                        }
                    </ul>
                    <a href="mailto:sales@chatportal.com" class="btn btn-outline-secondary w-100">Contact Sales</a>
                </div>
            </div>
        </div>
    </div>

    <!-- FAQ -->
    <div class="row justify-content-center mt-5">
        <div class="col-lg-8">
            <h3 class="fw-bold text-center mb-4">Frequently Asked Questions</h3>
            <div class="accordion" id="faqAccordion">
                @foreach (var faq in new[] {
                    ("What are credits?", "Credits are used each time you send a message to the AI. 1 credit ≈ 1,000 tokens.", 0),
                    ("Can I cancel anytime?", "Yes, you can cancel your subscription at any time with no penalties.", 1),
                    ("Is there a free trial?", "The Free plan is available forever with 100 credits per month.", 2)
                })
                {
                    <div class="accordion-item border-0 mb-2 shadow-sm rounded-3 overflow-hidden">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(faq.Item3 > 0 ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#faq@(faq.Item3)">
                                @faq.Item1
                            </button>
                        </h2>
                        <div id="faq@(faq.Item3)" class="accordion-collapse collapse @(faq.Item3 == 0 ? "show" : "")" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted small">@faq.Item2</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
