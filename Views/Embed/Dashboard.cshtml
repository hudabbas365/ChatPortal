@model ChatPortal.Models.Entities.Dashboard
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title — ChatPortal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: #f8f9fa; font-family: system-ui, sans-serif; }
        .embed-header { background: linear-gradient(135deg,#6366f1,#8b5cf6); color:#fff; padding:1.5rem; }
        .chart-card { border-radius:12px; border:none; box-shadow:0 2px 12px rgba(0,0,0,0.08); }
        .chart-placeholder { background:#f1f5f9; border-radius:8px; height:200px; display:flex; align-items:center; justify-content:center; }
        .powered { font-size:0.75rem; opacity:0.7; }
    </style>
</head>
<body>
    <div class="embed-header">
        <h4 class="mb-0 fw-bold">@Model.Title</h4>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="mb-0 mt-1 opacity-75 small">@Model.Description</p>
        }
    </div>

    <div class="p-3">
        @if (!Model.PinnedCharts.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-bar-chart fs-1 opacity-25"></i>
                <p class="mt-2">No charts available in this dashboard.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var chart in Model.PinnedCharts.OrderBy(c => c.Position))
                {
                    <div class="col-md-6">
                        <div class="card chart-card">
                            <div class="card-body">
                                <h6 class="fw-semibold mb-3">@chart.Title</h6>
                                <div class="chart-placeholder">
                                    <span class="text-muted"><i class="bi bi-bar-chart-fill fs-1 opacity-50"></i></span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="text-center p-3 powered text-muted">
        Powered by <strong>ChatPortal</strong>
    </div>
</body>
</html>
