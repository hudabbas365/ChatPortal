@{
    Layout = null; // No layout — self-contained for iframe embedding
    var token = ViewBag.Token as string ?? "";
    var models = ViewBag.AvailableModels as List<string> ?? new List<string> { "gpt-3.5-turbo" };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ChatPortal Embedded Chat</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body {
            margin: 0; padding: 0;
            width: 100%; height: 100%;
            font-family: system-ui, -apple-system, sans-serif;
            background: #0f1117;
            color: #e2e8f0;
            overflow: hidden;
        }
        .embed-container { display: flex; flex-direction: column; height: 100vh; }
        .embed-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 0.6rem 1rem;
            background: #1a1d2e;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            flex-shrink: 0;
        }
        .embed-header .brand { display: flex; align-items: center; gap: 0.5rem; font-weight: 600; font-size: 0.9rem; color: #e2e8f0; }
        .embed-messages { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 0.75rem; }
        .embed-input-area { padding: 0.75rem 1rem; background: #1a1d2e; border-top: 1px solid rgba(255,255,255,0.08); flex-shrink: 0; }
        .embed-input-row { display: flex; gap: 0.5rem; }
        .embed-textarea {
            flex: 1; background: #252836; border: 1px solid rgba(255,255,255,0.1);
            color: #e2e8f0; border-radius: 0.5rem; padding: 0.5rem 0.75rem;
            resize: none; font-size: 0.875rem; max-height: 120px; overflow-y: auto;
        }
        .embed-textarea:focus { outline: none; border-color: #0d6efd; box-shadow: 0 0 0 2px rgba(13,110,253,0.2); }
        .embed-textarea::placeholder { color: rgba(255,255,255,0.3); }
        .btn-send {
            background: #0d6efd; color: #fff; border: none; border-radius: 0.5rem;
            padding: 0.5rem 1rem; cursor: pointer; transition: background 0.15s; font-size: 0.875rem;
        }
        .btn-send:hover { background: #0b5ed7; }
        .btn-send:disabled { background: #374151; cursor: not-allowed; }
        .bubble-row { display: flex; gap: 0.5rem; }
        .bubble-row.user { justify-content: flex-end; }
        .bubble { padding: 0.6rem 0.9rem; border-radius: 0.75rem; max-width: 85%; font-size: 0.875rem; line-height: 1.5; }
        .bubble.ai { background: #252836; color: #e2e8f0; }
        .bubble.user { background: #0d6efd; color: #fff; white-space: pre-wrap; }
        .bubble pre { background: #1e1e2e; color: #cdd6f4; padding: 0.6rem; border-radius: 0.4rem; overflow-x: auto; font-size: 0.8rem; margin: 0.4rem 0; }
        .bubble code { background: rgba(0,0,0,0.2); padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.82em; }
        .avatar { width: 28px; height: 28px; border-radius: 50%; background: #0d6efd; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.75rem; }
        .typing-indicator { display: flex; gap: 4px; padding: 4px 0; }
        .typing-dot { width: 6px; height: 6px; border-radius: 50%; background: #6c757d; animation: typingBounce 1.2s infinite; }
        .typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .typing-dot:nth-child(3) { animation-delay: 0.4s; }
        @@keyframes typingBounce { 0%,80%,100% { transform: scale(0.7); opacity: 0.5; } 40% { transform: scale(1); opacity: 1; } }
        select.model-select { background: #252836; color: #e2e8f0; border: 1px solid rgba(255,255,255,0.1); border-radius: 0.4rem; padding: 0.2rem 0.4rem; font-size: 0.78rem; }
        .powered-by { text-align: center; font-size: 0.7rem; color: rgba(255,255,255,0.2); padding: 0.3rem; }
        .powered-by a { color: rgba(255,255,255,0.3); text-decoration: none; }
        .powered-by a:hover { color: #0d6efd; }
    </style>
</head>
<body>
    <div class="embed-container">
        <!-- Header -->
        <div class="embed-header">
            <div class="brand">
                <i class="bi bi-robot" style="color:#0d6efd;"></i>
                ChatPortal AI
            </div>
            <select class="model-select" id="embedModelSelect">
                @foreach (var aiModel in models)
                {
                    <option value="@aiModel">@aiModel</option>
                }
            </select>
        </div>

        <!-- Messages -->
        <div class="embed-messages" id="embedMessages">
            <div class="bubble-row" id="welcomeMsg">
                <div class="avatar"><i class="bi bi-robot" style="color:#fff;font-size:0.7rem;"></i></div>
                <div class="bubble ai">Hello! I'm ChatPortal AI. How can I help you today?</div>
            </div>
        </div>

        <!-- Input -->
        <div class="embed-input-area">
            @Html.AntiForgeryToken()
            <div class="embed-input-row">
                <textarea id="embedInput" class="embed-textarea" rows="1"
                          placeholder="Type a message…"
                          onkeydown="handleEmbedKeyDown(event)"
                          oninput="autoResizeEmbedTextarea(this)"></textarea>
                <button class="btn-send" id="embedSendBtn" onclick="sendEmbedMessage()">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
            <div class="powered-by">Powered by <a href="https://chatportal.ai" target="_blank" rel="noopener">ChatPortal</a></div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@@3.1.6/dist/purify.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Embed JWT token (server-rendered, stored only in JS)
        const EMBED_TOKEN = '@Html.Raw(System.Net.WebUtility.HtmlEncode(token))';

        if (typeof marked !== 'undefined') marked.setOptions({ breaks: true, gfm: true });

        /**
         * Append a message bubble to the embedded chat messages area.
         * @@param {string} role - "user" or "assistant".
         * @@param {string} content - Message text (Markdown supported for AI).
         */
        function appendEmbedMessage(role, content) {
            const isAi = role === 'assistant';
            const row = document.createElement('div');
            row.className = 'bubble-row' + (isAi ? '' : ' user');

            let bubbleHtml;
            if (isAi) {
                const md = (typeof marked !== 'undefined')
                    ? (typeof DOMPurify !== 'undefined' ? DOMPurify.sanitize(marked.parse(content, { breaks: true, gfm: true })) : marked.parse(content))
                    : escapeHtmlEmbed(content);
                bubbleHtml = `<div class="avatar"><i class="bi bi-robot" style="color:#fff;font-size:0.7rem;"></i></div>
                              <div class="bubble ai">${md}</div>`;
            } else {
                bubbleHtml = `<div class="bubble user">${escapeHtmlEmbed(content)}</div>`;
            }

            row.innerHTML = bubbleHtml;
            const container = document.getElementById('embedMessages');
            container.appendChild(row);

            // Syntax highlight new code blocks
            row.querySelectorAll('pre code:not(.hljs)').forEach(b => {
                if (typeof hljs !== 'undefined') hljs.highlightElement(b);
            });
            container.scrollTop = container.scrollHeight;
        }

        /**
         * Show or remove the typing indicator in the embedded messages area.
         * @@param {boolean} show - True to show, false to remove.
         */
        function setEmbedTyping(show) {
            const existing = document.getElementById('embedTyping');
            if (!show) { existing?.remove(); return; }
            if (existing) return;
            const row = document.createElement('div');
            row.id = 'embedTyping';
            row.className = 'bubble-row';
            row.innerHTML = `<div class="avatar"><i class="bi bi-robot" style="color:#fff;font-size:0.7rem;"></i></div>
                             <div class="bubble ai"><div class="typing-indicator">
                                 <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
                             </div></div>`;
            const c = document.getElementById('embedMessages');
            c.appendChild(row);
            c.scrollTop = c.scrollHeight;
        }

        /**
         * Send the typed message to the Embed/Send endpoint and display the AI reply.
         */
        async function sendEmbedMessage() {
            const input = document.getElementById('embedInput');
            const msg = input.value.trim();
            if (!msg) return;
            input.value = '';
            autoResizeEmbedTextarea(input);

            appendEmbedMessage('user', msg);
            setEmbedTyping(true);
            document.getElementById('embedSendBtn').disabled = true;

            try {
                const model = document.getElementById('embedModelSelect')?.value ?? 'gpt-3.5-turbo';
                const afToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                const res = await fetch('/Embed/Send', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': afToken,
                        'X-Embed-Token': EMBED_TOKEN
                    },
                    body: JSON.stringify({ message: msg, model, token: EMBED_TOKEN })
                });
                setEmbedTyping(false);
                if (res.ok) {
                    const data = await res.json();
                    appendEmbedMessage('assistant', data.content);
                } else {
                    const err = await res.json();
                    appendEmbedMessage('assistant', 'Error: ' + (err.error || 'Something went wrong.'));
                }
            } catch {
                setEmbedTyping(false);
                appendEmbedMessage('assistant', 'Connection error. Please check your network.');
            } finally {
                document.getElementById('embedSendBtn').disabled = false;
                input.focus();
            }
        }

        /**
         * Handle keydown in the embed textarea; submit on Enter without Shift.
         * @@param {KeyboardEvent} e - Keyboard event.
         */
        function handleEmbedKeyDown(e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendEmbedMessage(); }
            autoResizeEmbedTextarea(e.target);
        }

        /**
         * Auto-resize the embed textarea up to 120px height.
         * @@param {HTMLTextAreaElement} el - The textarea to resize.
         */
        function autoResizeEmbedTextarea(el) {
            el.style.height = 'auto';
            el.style.height = Math.min(el.scrollHeight, 120) + 'px';
        }

        /**
         * Escape HTML special characters to prevent XSS in user bubbles.
         * @@param {string} text - Raw string to escape.
         * @@returns {string} HTML-escaped string.
         */
        function escapeHtmlEmbed(text) {
            const d = document.createElement('div');
            d.appendChild(document.createTextNode(String(text)));
            return d.innerHTML;
        }
    </script>
</body>
</html>
