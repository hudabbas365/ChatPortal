@using ChatPortal.Models.Entities
@{
    ViewData["Title"] = "Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var announcements = (List<Announcement>?)ViewBag.Announcements ?? new List<Announcement>();
    string PriorityBadge(AnnouncementPriority p) => p switch {
        AnnouncementPriority.Urgent => "danger",
        AnnouncementPriority.Warning => "warning",
        _ => "info"
    };
}

<div class="container-fluid py-4" style="padding-top:76px!important;">
    <div class="row">
        <div class="col-lg-2 d-none d-lg-block">
            <partial name="_Sidebar" />
        </div>
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold mb-0">Admin Panel</h3>
                    <p class="text-muted small mb-0">Platform overview and management</p>
                </div>
            </div>

            <!-- Key Metrics -->
            <div class="row g-3 mb-4">
                @foreach (var item in new[] {
                    ("Total Users", ViewBag.TotalUsers?.ToString() ?? "0", "bi-people", "primary"),
                    ("Active Subscriptions", ViewBag.ActiveSubscriptions?.ToString() ?? "0", "bi-credit-card", "success"),
                    ("Total Revenue", ViewBag.TotalRevenue?.ToString() ?? "$0", "bi-cash-stack", "warning"),
                    ("API Calls Today", ViewBag.ApiCalls?.ToString() ?? "0", "bi-code-square", "info")
                })
                {
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <p class="text-muted small mb-1">@item.Item1</p>
                                        <h3 class="fw-bold mb-0">@item.Item2</h3>
                                    </div>
                                    <div class="bg-@item.Item4 bg-opacity-10 text-@item.Item4 rounded-3 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                                        <i class="bi @item.Item3 fs-5"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Quick Actions -->
            <div class="row g-3 mb-4">
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                            <h6 class="fw-bold">Quick Actions</h6>
                        </div>
                        <div class="card-body p-4">
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-outline-primary btn-sm"><i class="bi bi-people me-1"></i>Manage Users</button>
                                <button class="btn btn-outline-success btn-sm"><i class="bi bi-credit-card me-1"></i>Subscriptions</button>
                                <button class="btn btn-outline-info btn-sm"><i class="bi bi-cpu me-1"></i>AI Models</button>
                                <button class="btn btn-outline-warning btn-sm"><i class="bi bi-cash me-1"></i>Payments</button>
                                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-shield me-1"></i>Security Logs</button>
                                <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear me-1"></i>System Settings</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- System Status -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                    <h6 class="fw-bold">System Status</h6>
                </div>
                <div class="card-body p-4">
                    <div class="list-group list-group-flush">
                        @foreach (var svc in new[] {
                            ("API Server", "Operational", "success"),
                            ("Database", "Operational", "success"),
                            ("AI Service", "Operational", "success"),
                            ("Email Service", "Stub Mode", "warning"),
                            ("SignalR Hub", "Operational", "success")
                        })
                        {
                            <div class="list-group-item px-0 py-2 border-0 border-bottom d-flex justify-content-between align-items-center">
                                <span class="small fw-medium">@svc.Item1</span>
                                <span class="badge bg-@svc.Item3 bg-opacity-10 text-@svc.Item3">@svc.Item2</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Global Announcements Management -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0">Global Announcements</h6>
                    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createAnnouncementModal">
                        <i class="bi bi-plus-circle me-1"></i>New Announcement
                    </button>
                </div>
                <div class="card-body p-4">
                    @if (!announcements.Any())
                    {
                        <p class="text-muted small mb-0">No announcements yet. Create one to broadcast to all users.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="small">Title</th>
                                        <th class="small">Priority</th>
                                        <th class="small">Status</th>
                                        <th class="small">Created</th>
                                        <th class="small">Expires</th>
                                        <th class="small">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ann in announcements)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-medium small">@ann.Title</div>
                                                <div class="text-muted" style="font-size:0.72rem;">@(ann.Content.Length > 60 ? ann.Content[..60] + "…" : ann.Content)</div>
                                            </td>
                                            <td><span class="badge bg-@PriorityBadge(ann.Priority) bg-opacity-10 text-@PriorityBadge(ann.Priority)">@ann.Priority</span></td>
                                            <td>
                                                @if (ann.IsActive)
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td class="small text-muted">@ann.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                                            <td class="small text-muted">@(ann.ExpiresAt.HasValue ? ann.ExpiresAt.Value.ToLocalTime().ToString("MMM d, yyyy") : "—")</td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-secondary me-1"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#editAnnouncementModal"
                                                        data-id="@ann.Id"
                                                        data-title="@ann.Title"
                                                        data-content="@ann.Content"
                                                        data-priority="@ann.Priority"
                                                        data-isactive="@ann.IsActive.ToString().ToLower()"
                                                        data-expires="@(ann.ExpiresAt.HasValue ? ann.ExpiresAt.Value.ToString("yyyy-MM-ddTHH:mm") : "")">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <form asp-action="DeleteAnnouncement" asp-controller="Admin" method="post" class="d-inline"
                                                      onsubmit="return confirm('Delete this announcement?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@ann.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Announcement Modal -->
<div class="modal fade" id="createAnnouncementModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">
            <form asp-action="CreateAnnouncement" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="bi bi-megaphone me-2"></i>New Global Announcement</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Title</label>
                        <input type="text" name="title" class="form-control" required maxlength="256" placeholder="Announcement title…" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Content</label>
                        <textarea name="content" class="form-control" rows="4" required placeholder="Announcement message…"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Priority</label>
                        <select name="priority" class="form-select">
                            <option value="Informational">ℹ Informational</option>
                            <option value="Warning">⚠ Warning</option>
                            <option value="Urgent">🚨 Urgent</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Expires At <span class="text-muted">(optional)</span></label>
                        <input type="datetime-local" name="expiresAt" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-megaphone me-1"></i>Broadcast</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Announcement Modal -->
<div class="modal fade" id="editAnnouncementModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">
            <form asp-action="EditAnnouncement" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2"></i>Edit Announcement</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Title</label>
                        <input type="text" name="title" id="editTitle" class="form-control" required maxlength="256" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Content</label>
                        <textarea name="content" id="editContent" class="form-control" rows="4" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Priority</label>
                        <select name="priority" id="editPriority" class="form-select">
                            <option value="Informational">ℹ Informational</option>
                            <option value="Warning">⚠ Warning</option>
                            <option value="Urgent">🚨 Urgent</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Status</label>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="isActive" id="editIsActive" value="true" />
                            <label class="form-check-label small" for="editIsActive">Active (visible to users)</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Expires At <span class="text-muted">(optional)</span></label>
                        <input type="datetime-local" name="expiresAt" id="editExpiresAt" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('editAnnouncementModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('editId').value = btn.dataset.id;
            document.getElementById('editTitle').value = btn.dataset.title;
            document.getElementById('editContent').value = btn.dataset.content;
            document.getElementById('editPriority').value = btn.dataset.priority;
            document.getElementById('editIsActive').checked = btn.dataset.isactive === 'true';
            document.getElementById('editExpiresAt').value = btn.dataset.expires || '';
        });
    </script>
}
