@using ChatPortal.Models.Entities
@model List<GlobalAnnouncement>
@{
    ViewData["Title"] = "Announcements";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4" style="padding-top:76px!important;">
    <div class="row">
        <div class="col-lg-2 d-none d-lg-block">
            <partial name="_Sidebar" />
        </div>
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold mb-0">Global Announcements</h3>
                    <p class="text-muted small mb-0">Create and broadcast announcements to all users</p>
                </div>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
                    <i class="bi bi-megaphone me-1"></i>New Announcement
                </button>
            </div>

            <!-- Announcements Table -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-megaphone fs-1 text-muted"></i>
                            <p class="text-muted mt-3 mb-0">No announcements yet. Create one to get started.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="px-4">Title</th>
                                        <th>Priority</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th class="px-4">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ann in Model)
                                    {
                                        var (priorityBadge, priorityIcon) = ann.Priority switch
                                        {
                                            "urgent" => ("bg-danger", "bi-exclamation-triangle-fill"),
                                            "warning" => ("bg-warning text-dark", "bi-exclamation-circle-fill"),
                                            _ => ("bg-primary", "bi-info-circle-fill")
                                        };
                                        <tr>
                                            <td class="px-4 py-3">
                                                <div class="fw-semibold">@ann.Title</div>
                                                <div class="text-muted small text-truncate" style="max-width:300px;">@ann.Content</div>
                                            </td>
                                            <td class="py-3">
                                                <span class="badge @priorityBadge">
                                                    <i class="bi @priorityIcon me-1"></i>
                                                    @System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(ann.Priority)
                                                </span>
                                            </td>
                                            <td class="py-3">
                                                @if (ann.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td class="py-3 text-muted small">@ann.CreatedAt.ToString("MMM d, yyyy")</td>
                                            <td class="px-4 py-3">
                                                <div class="d-flex gap-1">
                                                    <!-- Broadcast -->
                                                    <form asp-action="BroadcastAnnouncement" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@ann.Id" />
                                                        <button type="submit" class="btn btn-outline-primary btn-sm" title="Broadcast to all users">
                                                            <i class="bi bi-broadcast"></i>
                                                        </button>
                                                    </form>
                                                    <!-- Edit -->
                                                    <button class="btn btn-outline-secondary btn-sm"
                                                            data-bs-toggle="modal" data-bs-target="#editModal-@ann.Id"
                                                            title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <!-- Delete -->
                                                    <form asp-action="DeleteAnnouncement" method="post" class="d-inline"
                                                          onsubmit="return confirm('Delete this announcement?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@ann.Id" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Announcement Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded-4">
            <form asp-action="CreateAnnouncement" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-megaphone me-2"></i>New Announcement</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body px-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Title <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" placeholder="Announcement title" required maxlength="256" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Content <span class="text-danger">*</span></label>
                        <textarea name="content" class="form-control" rows="4" placeholder="Announcement content…" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Priority</label>
                        <select name="priority" class="form-select">
                            <option value="informational">ℹ️ Informational</option>
                            <option value="warning">⚠️ Warning</option>
                            <option value="urgent">🚨 Urgent</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Announcement Modals -->
@foreach (var ann in Model)
{
    <div class="modal fade" id="editModal-@ann.Id" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content rounded-4">
                <form asp-action="EditAnnouncement" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@ann.Id" />
                    <div class="modal-header border-0">
                        <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2"></i>Edit Announcement</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body px-4">
                        <div class="mb-3">
                            <label class="form-label fw-medium">Title <span class="text-danger">*</span></label>
                            <input type="text" name="title" class="form-control" value="@ann.Title" required maxlength="256" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Content <span class="text-danger">*</span></label>
                            <textarea name="content" class="form-control" rows="4" required>@ann.Content</textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Priority</label>
                            <select name="priority" class="form-select edit-priority-select" data-selected="@ann.Priority">
                                <option value="informational">ℹ️ Informational</option>
                                <option value="warning">⚠️ Warning</option>
                                <option value="urgent">🚨 Urgent</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="isActive" value="true" id="isActive-@ann.Id" @(ann.IsActive ? "checked" : "") />
                                <label class="form-check-label" for="isActive-@ann.Id">Active (show banner to all users)</label>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.edit-priority-select').forEach(function (sel) {
            var val = sel.getAttribute('data-selected');
            if (val) sel.value = val;
        });
    });
</script>
}
