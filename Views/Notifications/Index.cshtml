@using ChatPortal.Models.Entities
@model List<Notification>
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4" style="padding-top:76px!important;">
    <div class="row">
        <div class="col-lg-2 d-none d-lg-block">
            <partial name="_Sidebar" />
        </div>
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold mb-0">Notifications</h3>
                    <p class="text-muted small mb-0">
                        @ViewBag.UnreadCount unread notification@(ViewBag.UnreadCount == 1 ? "" : "s")
                    </p>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-bell-slash fs-1 text-muted"></i>
                        <p class="text-muted mt-3 mb-0">You have no notifications.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="list-group list-group-flush rounded-4">
                        @foreach (var n in Model)
                        {
                            var (borderColor, iconClass) = n.Priority switch
                            {
                                "urgent" => ("border-danger", "bi-exclamation-triangle-fill text-danger"),
                                "warning" => ("border-warning", "bi-exclamation-circle-fill text-warning"),
                                _ => ("border-primary", "bi-info-circle-fill text-primary")
                            };
                            <div class="list-group-item list-group-item-action border-0 border-start border-3 @borderColor py-3 px-4 @(!n.IsRead ? "bg-light" : "")">
                                <div class="d-flex gap-3 align-items-start">
                                    <i class="bi @iconClass fs-5 flex-shrink-0 mt-1"></i>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <span class="fw-semibold @(!n.IsRead ? "" : "text-muted")">@n.Title</span>
                                            <small class="text-muted ms-2 flex-shrink-0">@n.CreatedAt.ToString("MMM d, yyyy HH:mm")</small>
                                        </div>
                                        <p class="mb-2 small @(!n.IsRead ? "" : "text-muted")">@n.Content</p>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <span class="badge rounded-pill @(n.Priority switch { "urgent" => "bg-danger", "warning" => "bg-warning text-dark", _ => "bg-primary" }) bg-opacity-10 text-@(n.Priority switch { "urgent" => "danger", "warning" => "dark", _ => "primary" })">
                                                @System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(n.Priority ?? "informational")
                                            </span>
                                            @if (!string.IsNullOrEmpty(n.Type))
                                            {
                                                <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary">@n.Type</span>
                                            }
                                            @if (n.IsRead)
                                            {
                                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success">Read</span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning">Unread</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="d-flex flex-column gap-1 flex-shrink-0">
                                        @if (!n.IsRead)
                                        {
                                            <form asp-action="MarkAsRead" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@n.Id" />
                                                <button type="submit" class="btn btn-outline-success btn-sm" title="Mark as read">
                                                    <i class="bi bi-check2 me-1"></i>Read
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="MarkAsUnread" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@n.Id" />
                                                <button type="submit" class="btn btn-outline-secondary btn-sm" title="Mark as unread">
                                                    <i class="bi bi-envelope me-1"></i>Unread
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Dismiss" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@n.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Dismiss">
                                                <i class="bi bi-x me-1"></i>Dismiss
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
