@model List<ChatPortal.Models.Entities.QueryHistory>
@{
    ViewData["Title"] = "Query History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-hero py-4 mb-4" style="background: linear-gradient(135deg, #E8F0FE 0%, #F3E8FF 100%);">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h1 class="h3 fw-bold mb-1"><i class="bi bi-clock-history me-2 text-primary"></i>Query History</h1>
                <p class="text-muted mb-0">Browse, search, and re-run your past data queries.</p>
            </div>
            <a asp-controller="DataInsights" asp-action="Index" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Back to Insights
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-clock-history display-1 text-muted opacity-25"></i>
            <h4 class="mt-3 text-muted">No query history yet</h4>
            <p class="text-muted">Start querying your data sources to build history.</p>
            <a asp-controller="DataInsights" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>Query Data
            </a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Data Source</th>
                                <th>Query</th>
                                <th>Narrative</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-nowrap text-muted small">@item.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@(item.DataSource?.Name ?? "Unknown")</span>
                                    </td>
                                    <td>
                                        <code class="small text-truncate d-inline-block" style="max-width:280px;" title="@item.Query">@item.Query</code>
                                    </td>
                                    <td class="small text-muted">
                                        @if (!string.IsNullOrEmpty(item.Narrative))
                                        {
                                            <span class="text-truncate d-inline-block" style="max-width:200px;" title="@item.Narrative">@item.Narrative</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            @if (!string.IsNullOrEmpty(item.ChartDataJson))
                                            {
                                                <button class="btn btn-outline-primary btn-sm" onclick="viewChart(@item.Id)" title="View Chart">
                                                    <i class="bi bi-bar-chart"></i>
                                                </button>
                                            }
                                            <a asp-controller="DataInsights" asp-action="Index" asp-route-rerunQuery="@item.Query" asp-route-dataSourceId="@item.DataSourceId"
                                               class="btn btn-outline-success btn-sm" title="Re-run">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </a>
                                            <form method="post" asp-controller="DataInsights" asp-action="DeleteHistory" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete" onclick="return confirm('Delete this history entry?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
function viewChart(id) {
    fetch('/DataInsights/HistoryChart/' + id)
        .then(r => r.json())
        .then(data => {
            if (data.chartDataJson) {
                alert('Chart data: ' + data.chartDataJson.substring(0, 200) + '...');
            }
        });
}
</script>
}
