@model ChatPortal.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page d-flex align-items-center justify-content-center py-5" style="min-height:100vh;padding-top:100px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                 style="width:64px;height:64px;background:rgba(143,217,251,0.15);">
                                <i class="bi bi-robot fs-2" style="color:var(--cp-accent,#8FD9FB);"></i>
                            </div>
                            <h2 class="fw-bold">Welcome back</h2>
                            <p class="text-muted">Sign in to your ChatPortal account</p>
                        </div>

                        <!-- Office 365 Sign-In -->
                        <a href="/Account/LoginMicrosoft" class="btn w-100 mb-3 d-flex align-items-center justify-content-center gap-2"
                           style="background:#fff;border:1px solid #dee2e6;color:#333;font-weight:500;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 23 23">
                                <path fill="#f35325" d="M0 0h11v11H0z"/>
                                <path fill="#81bc06" d="M12 0h11v11H12z"/>
                                <path fill="#05a6f0" d="M0 12h11v11H0z"/>
                                <path fill="#ffba08" d="M12 12h11v11H12z"/>
                            </svg>
                            Sign in with Microsoft / Office 365
                        </a>

                        <div class="d-flex align-items-center gap-2 mb-3">
                            <hr class="flex-grow-1 m-0" />
                            <span class="text-muted small">or</span>
                            <hr class="flex-grow-1 m-0" />
                        </div>

                        <form asp-action="Login" method="post">
                            <input type="hidden" asp-for="ReturnUrl" />
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-medium">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-body-secondary border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="you@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <label asp-for="Password" class="form-label fw-medium">Password</label>
                                    <a href="#" class="small text-decoration-none" style="color:var(--cp-accent,#8FD9FB);">Forgot password?</a>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text bg-body-secondary border-end-0"><i class="bi bi-lock text-muted"></i></span>
                                    <input asp-for="Password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4 d-flex align-items-center justify-content-between">
                                <div class="form-check">
                                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                                    <label asp-for="RememberMe" class="form-check-label small">Remember me</label>
                                </div>
                            </div>

                            <button type="submit" class="btn w-100 btn-lg mb-3"
                                    style="background:var(--cp-accent,#8FD9FB);color:var(--cp-primary-text,#1a5276);font-weight:600;">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                            </button>

                            <div class="text-center">
                                <span class="text-muted small">Don't have an account? </span>
                                <a asp-action="Register" class="small fw-medium text-decoration-none" style="color:var(--cp-accent,#8FD9FB);">Sign up free</a>
                            </div>
                        </form>

                        <div class="mt-4 p-3 bg-body-secondary rounded-3">
                            <p class="small text-muted mb-1 fw-medium">Demo credentials:</p>
                            <p class="small mb-0">Admin: <code>admin@chatportal.com</code> / <code>Admin@123</code></p>
                            <p class="small mb-0">User: <code>demo@chatportal.com</code> / <code>Demo@123</code></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
