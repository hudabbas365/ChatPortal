@model ChatPortal.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3 mb-4">
            <partial name="_Sidebar" />
        </div>
        <div class="col-lg-9">
            <h3 class="fw-bold mb-4">Account Settings</h3>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">Profile Information</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Settings" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-medium">First Name</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-medium">Last Name</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-medium">Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="AvatarUrl" class="form-label fw-medium">Avatar URL</label>
                            <input asp-for="AvatarUrl" class="form-control" placeholder="https://..." />
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">Change Password</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Settings" method="post">
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-medium">Current Password</label>
                            <input asp-for="CurrentPassword" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-medium">New Password</label>
                            <input asp-for="NewPassword" class="form-control" />
                        </div>
                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-medium">Confirm New Password</label>
                            <input asp-for="ConfirmNewPassword" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="bi bi-shield-lock me-1"></i>Update Password
                        </button>
                    </form>
                </div>
            </div>

            @if (ViewBag.IsAgent == true || User.Identity?.IsAuthenticated == true)
            {
                <div class="card border-0 shadow-sm rounded-4 mt-4">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <h5 class="fw-bold mb-0"><i class="bi bi-code-slash me-2 text-primary"></i>Embed &amp; iFrame Publishing</h5>
                    </div>
                    <div class="card-body p-4">
                        <p class="text-muted small mb-3">
                            Generate an embed token to publish your ChatPortal conversation as an iFrame on any external website.
                        </p>
                        <div class="d-flex gap-2 mb-3">
                            <button class="btn btn-primary btn-sm" id="settingsGenerateTokenBtn" onclick="settingsGenerateToken()">
                                <i class="bi bi-key me-1"></i>Generate Embed Token
                            </button>
                            <span id="settingsTokenStatus" class="small text-muted align-self-center"></span>
                        </div>
                        <div id="settingsEmbedSection" class="d-none">
                            <label class="form-label fw-semibold small">Embed Token</label>
                            <div class="input-group input-group-sm mb-3">
                                <input type="text" id="settingsTokenDisplay" class="form-control font-monospace small" readonly />
                                <button class="btn btn-outline-secondary" type="button" onclick="copyText('settingsTokenDisplay')">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>
                            <label class="form-label fw-semibold small">iFrame Snippet</label>
                            <div class="input-group input-group-sm">
                                <textarea id="settingsIframeCode" class="form-control font-monospace small" rows="3" readonly></textarea>
                                <button class="btn btn-outline-secondary" type="button" onclick="copyText('settingsIframeCode')">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>
                            <p class="text-muted mt-2" style="font-size:0.78rem;">
                                <i class="bi bi-info-circle me-1"></i>Paste the snippet into any HTML page to embed the chat interface.
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (ViewBag.IsAgent == true || User.Identity?.IsAuthenticated == true)
    {
        <script>
            function getAntiForgeryToken() {
                return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            }

            async function settingsGenerateToken() {
                const btn = document.getElementById('settingsGenerateTokenBtn');
                const status = document.getElementById('settingsTokenStatus');
                btn.disabled = true;
                status.textContent = 'Generating…';
                try {
                    const resp = await fetch('/Account/GenerateEmbedToken', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': getAntiForgeryToken()
                        }
                    });
                    const data = await resp.json();
                    if (data.success && data.token) {
                        const origin = window.location.origin;
                        const iframeUrl = `${origin}/Embed/Chat?token=${encodeURIComponent(data.token)}`;
                        document.getElementById('settingsTokenDisplay').value = data.token;
                        document.getElementById('settingsIframeCode').value =
                            `<iframe src="${iframeUrl}" width="400" height="600" frameborder="0" allow="microphone"></iframe>`;
                        document.getElementById('settingsEmbedSection').classList.remove('d-none');
                        status.textContent = '';
                    } else {
                        status.textContent = data.error || 'Failed to generate token.';
                    }
                } catch {
                    status.textContent = 'Request failed. Please try again.';
                } finally {
                    btn.disabled = false;
                }
            }

            function copyText(elementId) {
                const el = document.getElementById(elementId);
                navigator.clipboard?.writeText(el.value).catch(() => { el.select(); document.execCommand('copy'); });
            }
        </script>
    }
}
