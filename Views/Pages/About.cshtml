@{
    ViewData["Title"] = "About ChatPortal — AI-Powered Chat Platform";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="bg-dark text-white py-5">
    <div class="container py-4">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="badge bg-primary mb-3">Our Story</span>
                <h1 class="display-4 fw-bold mb-4">Building the Future of <span class="text-primary">AI-Powered Conversation</span></h1>
                <p class="lead text-muted mb-4">
                    ChatPortal was founded with a single mission: make powerful AI conversation tools accessible
                    to everyone — from individual developers to enterprise teams — without complexity or compromise.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Chat" class="btn btn-primary btn-lg"><i class="bi bi-chat-dots me-2"></i>Start Chatting Free</a>
                    <a href="/Pages/Docs" class="btn btn-outline-light btn-lg"><i class="bi bi-book me-2"></i>Read the Docs</a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center mt-4 mt-lg-0">
                <div class="rounded-4 p-4" style="background:rgba(13,110,253,0.1);border:1px solid rgba(13,110,253,0.3);">
                    <i class="bi bi-robot text-primary" style="font-size:5rem;"></i>
                    <div class="mt-3 text-muted small">Powered by OpenAI · Built on ASP.NET Core</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Banner -->
<section class="py-4 bg-primary bg-opacity-10 border-top border-bottom border-primary border-opacity-25">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3">
                <div class="fw-bold fs-3 text-primary">50K+</div>
                <div class="text-muted small">Active Users</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold fs-3 text-primary">5M+</div>
                <div class="text-muted small">Messages Sent</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold fs-3 text-primary">99.9%</div>
                <div class="text-muted small">Uptime SLA</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="fw-bold fs-3 text-primary">15+</div>
                <div class="text-muted small">AI Models</div>
            </div>
        </div>
    </div>
</section>

<!-- Our Story -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center mb-5">
                <h2 class="fw-bold">How ChatPortal Came to Be</h2>
                <p class="text-muted">A developer's frustration turned into a platform thousands rely on every day.</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4">
                    <div class="text-primary mb-3"><i class="bi bi-lightbulb fs-2"></i></div>
                    <h5 class="fw-bold">The Problem We Solved</h5>
                    <p class="text-muted">
                        In 2023, our founding team — a group of software engineers — found that integrating
                        large language models into real products was unnecessarily complex. Authentication,
                        rate limiting, conversation context, and data privacy were each separate challenges.
                        We built ChatPortal to wrap all of that into one coherent, developer-friendly platform.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 border-0 shadow-sm p-4">
                    <div class="text-primary mb-3"><i class="bi bi-rocket-takeoff fs-2"></i></div>
                    <h5 class="fw-bold">Growth & Today</h5>
                    <p class="text-muted">
                        What started as an internal tool grew into a fully-fledged SaaS product used by
                        startups, agencies, and enterprise customers in over 40 countries. We process
                        millions of AI requests every month while keeping our platform fast, secure, and
                        affordable through a transparent credit-based pricing model.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values -->
<section class="py-5 bg-body-secondary">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Our Core Values</h2>
            <p class="text-muted">The principles that guide every decision we make.</p>
        </div>
        <div class="row g-4">
            @foreach (var value in new[] {
                ("bi-shield-check", "Privacy First", "Your conversations are yours. Browser-based history means your data never leaves your device unless you choose to share it."),
                ("bi-lightning-charge", "Speed & Reliability", "Sub-second response times and a 99.9% SLA backed by redundant infrastructure across multiple regions."),
                ("bi-people", "Developer Friendly", "Clean REST APIs, comprehensive docs, JWT authentication, and an iframe embed kit — integrate in minutes, not days."),
                ("bi-currency-dollar", "Transparent Pricing", "No hidden fees. Buy credits upfront, use them at your own pace. Unused credits never expire.")
            })
            {
                <div class="col-sm-6 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm text-center p-4">
                        <i class="bi @value.Item1 text-primary fs-2 mb-3"></i>
                        <h6 class="fw-bold">@value.Item2</h6>
                        <p class="text-muted small mb-0">@value.Item3</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Technology Stack -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Technology Stack</h2>
            <p class="text-muted">Built with battle-tested, open-source technologies.</p>
        </div>
        <div class="row g-3 justify-content-center">
            @foreach (var tech in new[] {
                ("ASP.NET Core 8", "Microsoft's high-performance web framework", "bi-microsoft"),
                ("OpenAI API", "GPT-3.5, GPT-4, and beyond", "bi-stars"),
                ("SignalR", "Real-time streaming AI responses", "bi-broadcast"),
                ("Entity Framework Core", "Type-safe database access with SQL Server", "bi-database"),
                ("JWT Authentication", "Stateless, secure token-based auth", "bi-key"),
                ("Bootstrap 5", "Responsive, accessible UI components", "bi-layout-text-sidebar"),
                ("Docker / Azure", "Containerised deployments at scale", "bi-cloud-upload"),
                ("highlight.js", "Beautiful code syntax highlighting", "bi-code-slash")
            })
            {
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm text-center p-3 h-100">
                        <i class="bi @tech.Item3 text-primary mb-2 fs-4"></i>
                        <div class="fw-semibold small">@tech.Item1</div>
                        <div class="text-muted" style="font-size:0.75rem;">@tech.Item2</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Team -->
<section class="py-5 bg-body-secondary">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Meet the Team</h2>
            <p class="text-muted">Small team, big impact — passionate about making AI accessible.</p>
        </div>
        <div class="row g-4 justify-content-center">
            @foreach (var member in new[] {
                ("Alex Chen", "Founder & CEO", "bi-person-circle", "Full-stack engineer with 12 years' experience building developer tools."),
                ("Priya Nair", "Head of AI Research", "bi-person-circle", "ML Engineer specialising in LLM fine-tuning and safety alignment."),
                ("Marcus Webb", "Lead Backend Engineer", "bi-person-circle", "ASP.NET Core expert and open-source contributor."),
                ("Sofia Reyes", "Product Designer", "bi-person-circle", "UX designer focused on making complex AI feel intuitive.")
            })
            {
                <div class="col-sm-6 col-lg-3">
                    <div class="card border-0 shadow-sm text-center p-4 h-100">
                        <i class="bi @member.Item3 text-primary mb-3" style="font-size:3rem;"></i>
                        <h6 class="fw-bold mb-1">@member.Item1</h6>
                        <div class="text-primary small mb-2">@member.Item2</div>
                        <p class="text-muted small mb-0">@member.Item4</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5 bg-primary text-white text-center">
    <div class="container">
        <h2 class="fw-bold mb-3">Ready to Experience the Future of AI Chat?</h2>
        <p class="lead mb-4 opacity-75">Join thousands of users already chatting smarter with ChatPortal.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/Account/Register" class="btn btn-light btn-lg fw-semibold"><i class="bi bi-person-plus me-2"></i>Sign Up Free</a>
            <a href="/Pages/Docs" class="btn btn-outline-light btn-lg"><i class="bi bi-book me-2"></i>Explore the API</a>
        </div>
    </div>
</section>
